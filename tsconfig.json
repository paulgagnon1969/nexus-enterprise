{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@repo/types/*": [
        "packages/types/src/*"
      ],
      "@repo/icc-client": [
        "packages/icc-client/dist/index.d.ts"
      ],
      "@repo/icc-client/*": [
        "packages/icc-client/dist/*"
      ]
    }
  }
}

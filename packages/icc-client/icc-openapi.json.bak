            "lang": "CURL",
            "source": "curl -X GET \"https://api.iccsafe.org/v1/book/{bookId}/chapters\" -H \"accept: application/json\" -H \"Authorization: Bearer {OAuth Token}\""
          },
          {
            "lang": "JavaScript",
            "source": "var request = new XMLHttpRequest();\n//Add X-AUTH-TOKEN header\nrequest.setRequestHeader('Authorization', 'Bearer {OAuth Token}',);\nrequest.open('GET', 'https://api.iccsafe.org/v1/book/{bookId}/chapters', true);\nrequest.onload = function () {\n    //Access Response Data\n    var data = JSON.parse(this.response);\n    if (request.status >= 200 && request.status < 400) {\n        data.chapters.forEach(chapter => {\n            console.log(chapter.ordinal . ' ' . chapter.title);\n        });\n    } else {\n        //Error\n    }\n}"
          }
        ]
      }
    },

// ===================================================================
// Prescreening Feedback — learning loop for smart project allocation
// ===================================================================

enum PrescreenFeedbackType {
  ACCEPTED
  REJECTED
  OVERRIDDEN
}

/// Records user feedback on prescreened transaction-to-project matches.
/// Used by the learning algorithm to improve future confidence scores.
model PrescreenFeedback {
  id                  String                @id @default(cuid())
  companyId           String
  transactionId       String // ImportedTransaction.id
  prescreenProjectId  String? // What was suggested
  actualProjectId     String? // What user chose (null if rejected outright)
  feedbackType        PrescreenFeedbackType
  reason              String? // User explanation
  source              String? // CsvImportSource at feedback time
  merchant            String?
  jobNameNormalized   String? // Captured for pattern learning
  storeNumber         String? // Captured for store-affinity learning
  purchaser           String? // Captured for purchaser-affinity learning
  descriptionKeywords String? // Extracted keywords for description-pattern learning
  createdByUserId     String?
  createdAt           DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, source, merchant], map: "PrescreenFeedback_company_source_merchant_idx")
  @@index([companyId, jobNameNormalized], map: "PrescreenFeedback_company_jobName_idx")
  @@index([companyId, storeNumber], map: "PrescreenFeedback_company_store_idx")
}

// ===================================================================
// Local Supplier Index — scraped geographic suppliers
// ===================================================================

enum LocalSupplierStatus {
  ACTIVE
  PENDING_REMOVAL
  PERMANENTLY_CLOSED
}

/// A scraped or manually-added local supplier associated with a company.
/// Records are never hard-deleted; status transitions track the full lifecycle.
model LocalSupplier {
  id        String  @id @default(cuid())
  companyId String
  name      String
  address   String?
  phone     String?
  website   String?
  lat       Float
  lng       Float
  category  String? // e.g. "Lumber", "Roofing", "Electrical"
  source    String? // e.g. "google_places", "manual"
  placeId   String? // Google Places ID for de-duplication

  // NexFIND additions
  globalSupplierId String? // FK → GlobalSupplier (network index)
  savedVia         String? // how the supplier entered: 'google_places', 'receipt_ocr', 'directions', 'manual'
  metadata         Json? // visit count, last navigated, tenant-private notes

  status LocalSupplierStatus @default(ACTIVE)

  // Flag / review audit trail
  flaggedByUserId  String?
  flaggedAt        DateTime?
  flagReason       String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  flaggedBy      User?           @relation("LocalSupplierFlaggedBy", fields: [flaggedByUserId], references: [id])
  reviewedBy     User?           @relation("LocalSupplierReviewedBy", fields: [reviewedByUserId], references: [id])
  globalSupplier GlobalSupplier? @relation(fields: [globalSupplierId], references: [id])

  @@unique([companyId, placeId], map: "LocalSupplier_company_placeId_key")
  @@index([companyId, status], map: "LocalSupplier_company_status_idx")
  @@index([companyId, lat, lng], map: "LocalSupplier_company_geo_idx")
  @@index([globalSupplierId], map: "LocalSupplier_global_supplier_idx")
}

// ===================================================================
// NexFIND — Global Supplier Network Index (cross-tenant)
// ===================================================================

/// System-wide supplier record aggregated from all tenants.
/// No companyId — this is the shared network index.
/// Tenant-specific data stays in LocalSupplier; this is anonymized aggregate.
model GlobalSupplier {
  id          String  @id @default(cuid())
  name        String
  address     String?
  phone       String?
  website     String?
  lat         Float
  lng         Float
  category    String? // e.g. "Hardware Store", "Lumber Yard"
  placeId     String? @unique(map: "GlobalSupplier_placeId_key")
  source      String? // first source: 'google_places', 'receipt_ocr', 'directions', 'manual'
  tenantCount Int     @default(1) // how many tenants have this supplier saved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  localSuppliers LocalSupplier[]

  @@index([lat, lng], map: "GlobalSupplier_geo_idx")
  @@index([category], map: "GlobalSupplier_category_idx")
}

// ===================================================================
// Room Scanner & Assessment — LiDAR + AI Vision dual-mode
// ===================================================================

/// A room scan captured via LiDAR (RoomPlan on iOS) or AI Vision (photo analysis).
/// Both modes produce a unified assessmentJson with room type, dimensions,
/// features (doors, windows, fixtures), and condition ratings.
model RoomScan {
  id              String   @id @default(cuid())
  companyId       String
  projectId       String
  particleId      String? /// FK → ProjectParticle (room in org tree)
  label           String? /// User-provided room label
  scanMode        String   @default("AI_VISION") /// AI_VISION | LIDAR
  status          String   @default("PROCESSING") /// PROCESSING | COMPLETE | FAILED
  photoUrls       Json? /// string[] of GCS URLs (photos used for AI Vision or LiDAR screenshots)
  assessmentJson  Json? /// Unified structured assessment (same shape for both modes)
  rawAiResponse   String?  @db.Text /// Raw GPT-4o response (AI_VISION mode only)
  lidarRoomJson   Json? /// Raw RoomPlan CapturedRoom data (LIDAR mode only)
  confidenceScore Float? /// 0.0–1.0 (high for LiDAR, variable for AI)
  errorMessage    String? /// Error details if status = FAILED
  notes           String?  @db.Text
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company   Company          @relation(fields: [companyId], references: [id])
  project   Project          @relation(fields: [projectId], references: [id])
  particle  ProjectParticle? @relation(fields: [particleId], references: [id])
  createdBy User             @relation("RoomScanCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, projectId], map: "RoomScan_company_project_idx")
  @@index([projectId, createdAt], map: "RoomScan_project_created_idx")
}

// ===================================================================
// Asset Scanner — 3D Object Capture + AI Tag Read + Fleet Onboarding
// ===================================================================

/// Records each asset scan event (3D capture, tag read, or fleet serial read).
/// Stores raw outputs (USDZ model, GPT-4o extractions) and links to the
/// resulting Asset after creation.
model AssetScan {
  id        String  @id @default(cuid())
  companyId String
  assetId   String? /// Linked to the resulting Asset after creation
  scanType  String /// OBJECT_CAPTURE | TAG_READ | FLEET_SERIAL
  status    String  @default("PROCESSING") /// PROCESSING | COMPLETE | FAILED

  // Object Capture outputs
  modelUrl     String? /// GCS URL to USDZ 3D model
  thumbnailUrl String? /// GCS URL to preview image
  boundingBox  Json? /// { min: [x,y,z], max: [x,y,z] } in meters
  dimensions   Json? /// { length, width, height, unit }

  // Tag Read / Serial Read outputs
  tagPhotoUrl       String? /// GCS URL to compressed nameplate photo (used for AI analysis)
  originalPhotoUrls Json? /// string[] of GCS URLs for original hi-res tag photos (uploaded after user verification)
  extractedData     Json? /// GPT-4o extracted: { manufacturer, model, serial, specs }
  rawAiResponse     String? @db.Text /// Raw GPT-4o response text

  // Common
  errorMessage String? /// Error details if status = FAILED
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  asset     Asset?  @relation(fields: [assetId], references: [id])
  createdBy User    @relation("AssetScanCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, createdAt], map: "AssetScan_company_created_idx")
  @@index([companyId, scanType], map: "AssetScan_company_type_idx")
  @@index([assetId], map: "AssetScan_asset_idx")
}

// ===================================================================
// Email Receipt Capture — supplier receipts from email
// ===================================================================

/// A receipt ingested from a monitored email inbox (e.g. ncc-email@nfsgrp.com).
/// Tracks the full lifecycle: email ingestion → OCR → auto-match → PM review.
model EmailReceipt {
  id                 String @id @default(cuid())
  companyId          String
  tenantEmailAddress String /// The inbox this was received on (e.g. ncc-email@nfsgrp.com)

  // Email metadata
  senderEmail  String
  subject      String?
  receivedAt   DateTime
  messageId    String?  @unique /// IMAP Message-ID for de-duplication
  rawEmailJson Json? /// Full parsed email for audit trail

  // Attachment storage
  attachmentUrls Json? /// JSON string[] of GCS URLs for receipt images/PDFs

  // Processing status
  status EmailReceiptStatus @default(PENDING_OCR)

  // OCR linkage (populated after OCR completes)
  ocrResultId String? @unique

  // Auto-match results
  projectId       String? /// Set when matched or assigned to a project
  matchConfidence Float? /// 0-1 confidence score from auto-match heuristic
  matchReason     String? /// Human-readable explanation (e.g. "Store #0604 near 123 Main St")

  // Manual assignment by PM
  assignedByUserId String?
  assignedAt       DateTime?

  // Connector linkage (which configured mailbox this came from)
  connectorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ocrResult  ReceiptOcrResult?      @relation(fields: [ocrResultId], references: [id], onDelete: SetNull)
  assignedBy User?                  @relation("EmailReceiptAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  connector  EmailReceiptConnector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)

  @@index([companyId, status], map: "EmailReceipt_company_status_idx")
  @@index([companyId, projectId], map: "EmailReceipt_company_project_idx")
  @@index([companyId, receivedAt], map: "EmailReceipt_company_received_idx")
  @@index([connectorId], map: "EmailReceipt_connector_idx")
}

// ===================================================================
// Email Receipt Connectors — tenant-configurable mailbox connections
// ===================================================================

enum EmailReceiptConnectorStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

/// A configured IMAP mailbox that the receipt poller reads from.
/// Tenants can add multiple connectors to monitor several inboxes.
model EmailReceiptConnector {
  id        String @id @default(cuid())
  companyId String
  label     String /// Friendly name (e.g. "HD Receipts Inbox")

  // IMAP connection details
  imapHost              String /// e.g. imap.gmail.com
  imapPort              Int    @default(993)
  imapUser              String /// e.g. ncc-email@nfsgrp.com
  imapPasswordEncrypted Bytes /// AES-256-GCM encrypted password
  imapMailbox           String @default("INBOX")

  // Status & tracking
  status                EmailReceiptConnectorStatus @default(ACTIVE)
  lastPolledAt          DateTime?
  lastPollError         String? /// Last error message if poll failed
  totalReceiptsIngested Int                         @default(0)

  // Audit
  connectedByUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connectedBy User           @relation("EmailReceiptConnectorConnectedBy", fields: [connectedByUserId], references: [id])
  receipts    EmailReceipt[]

  @@unique([companyId, imapUser, imapMailbox], name: "EmailReceiptConnector_company_user_mailbox_key")
  @@index([companyId, status], map: "EmailReceiptConnector_company_status_idx")
}

// ===================================================================
// NexLevelIntegration — AI-powered Video Property Assessments
// ===================================================================

enum VideoAssessmentSourceType {
  DRONE
  HANDHELD
  OTHER
}

enum VideoAssessmentStatus {
  PROCESSING
  COMPLETE
  FAILED
  REVIEWED
}

enum FindingZone {
  ROOF
  SIDING
  WINDOWS
  GUTTERS
  FASCIA_SOFFIT
  FOUNDATION
  DECK_PATIO
  FENCING
  LANDSCAPING
  INTERIOR_WALLS
  INTERIOR_CEILING
  INTERIOR_FLOOR
  INTERIOR_CABINETS
  INTERIOR_FIXTURES
  PLUMBING
  ELECTRICAL
  HVAC
  OTHER
}

enum FindingCategory {
  MISSING_SHINGLES
  CURLING
  GRANULE_LOSS
  HAIL_IMPACT
  WIND_LIFT
  ALGAE_MOSS
  FLASHING
  RIDGE_CAP
  VALLEY
  UNDERLAYMENT
  DRAINAGE
  CRACKING
  PEELING
  ROT
  WATER_STAIN
  MOLD
  WARPING
  BROKEN_SEAL
  MISSING_CAULK
  STRUCTURAL_SHIFT
  CORROSION
  INSECT_DAMAGE
  EFFLORESCENCE
  SPALLING
  OTHER
}

enum FindingSeverity {
  LOW
  MODERATE
  SEVERE
  CRITICAL
}

enum FindingCausation {
  HAIL
  WIND
  AGE
  WATER
  FIRE
  IMPACT
  THERMAL
  IMPROPER_INSTALL
  SETTLING
  PEST
  UNKNOWN
}

/// A video-based property assessment created by the NexLevelIntegration sync
/// client. The video itself stays on the local machine; only extracted frames,
/// AI-generated findings, and metadata are synced to the server.
/// When projectId is null the assessment sits in the unassigned bucket.
model VideoAssessment {
  id        String  @id @default(cuid())
  companyId String
  projectId String? /// nullable — unassigned bucket until linked to a project

  sourceType VideoAssessmentSourceType @default(OTHER)
  status     VideoAssessmentStatus     @default(PROCESSING)

  /// Video metadata (video stays local — only metadata stored)
  videoFileName     String?
  videoDurationSecs Int?
  videoResolution   String? /// e.g. "3840x2160"
  frameCount        Int? /// number of frames analyzed by AI

  /// AI analysis outputs
  thumbnailUrls   Json? /// string[] of GCS URLs for key frame thumbnails
  assessmentJson  Json? /// structured output: narrative + summary + costbook items
  rawAiResponse   String? @db.Text /// full Gemini response for audit trail
  confidenceScore Float? /// 0.0–1.0 overall confidence

  /// Context for causation analysis
  weatherContext String? /// optional weather at time of capture
  captureDate    DateTime? /// when the video was recorded

  errorMessage String? /// error details if status = FAILED
  notes        String? @db.Text

  /// Assignment tracking (bucket → project)
  assignedById String?
  assignedAt   DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// NLI provenance — which device and scanned file produced this assessment
  nliDeviceId      String?
  nliScannedFileId String?

  company          Company                     @relation(fields: [companyId], references: [id])
  project          Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy        User                        @relation("VideoAssessmentCreatedBy", fields: [createdById], references: [id])
  assignedBy       User?                       @relation("VideoAssessmentAssignedBy", fields: [assignedById], references: [id])
  nliDevice        NliDevice?                  @relation(fields: [nliDeviceId], references: [id], onDelete: SetNull)
  nliScannedFile   NliScannedFile?             @relation(fields: [nliScannedFileId], references: [id], onDelete: SetNull)
  findings         VideoAssessmentFinding[]
  teachingExamples AssessmentTeachingExample[]

  @@index([companyId, status], map: "VideoAssessment_company_status_idx")
  @@index([companyId, projectId], map: "VideoAssessment_company_project_idx")
  @@index([companyId, createdAt], map: "VideoAssessment_company_created_idx")
  @@index([nliDeviceId], map: "VideoAssessment_nli_device_idx")
}

/// An individual damage finding within a video assessment.
/// Each finding maps to a specific frame timestamp and includes
/// zone, category, severity, causation, and optional NCC costbook mapping.
model VideoAssessmentFinding {
  id           String @id @default(cuid())
  assessmentId String
  companyId    String

  zone      FindingZone
  category  FindingCategory
  severity  FindingSeverity
  causation FindingCausation @default(UNKNOWN)

  description     String? @db.Text /// AI-generated narrative for this finding
  frameTimestamp  Float? /// seconds into video where damage was spotted
  thumbnailUrl    String? /// GCS URL of the specific frame
  boundingBoxJson Json? /// optional { x, y, w, h } of damage area in frame

  /// NCC costbook mapping
  costbookItemCode  String? /// NCC costbook item code for estimating
  estimatedQuantity Float?
  estimatedUnit     String? /// e.g. "SQ", "LF", "SF", "EA"

  confidenceScore Float? /// 0.0–1.0 for this individual finding
  sortOrder       Int    @default(0)

  /// Human override tracking
  overriddenByUserId String?
  overriddenAt       DateTime?
  /// Snapshot of the original AI-generated values before human correction.
  /// Stored as JSON: { zone, category, severity, causation, description, ... }
  /// Used by the learning system to inject past corrections into future prompts.
  originalValuesJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment   VideoAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  company      Company         @relation(fields: [companyId], references: [id])
  overriddenBy User?           @relation("VideoFindingOverriddenBy", fields: [overriddenByUserId], references: [id])

  @@index([assessmentId], map: "VideoAssessmentFinding_assessment_idx")
  @@index([companyId, zone], map: "VideoAssessmentFinding_company_zone_idx")
  @@index([companyId, category], map: "VideoAssessmentFinding_company_category_idx")
  @@index([companyId, overriddenAt], map: "VideoAssessmentFinding_company_overridden_idx")
}

/// A "Zoom & Teach" interaction where a user crops/zooms into a specific
/// area of a frame, provides context, and the AI re-analyzes with Google
/// Search grounding for reference materials. Confirmed examples are injected
/// as few-shot context into future assessments for this company.
model AssessmentTeachingExample {
  id           String @id @default(cuid())
  companyId    String
  assessmentId String

  /// Which frame in the original assessment was selected
  frameIndex      Int
  /// Normalized crop box { x, y, w, h } (0.0-1.0)
  cropBox         Json?
  /// GCS URI of the cropped/zoomed image sent to Gemini
  croppedImageUri String?
  /// GCS URI of the full frame (fallback if no crop)
  fullFrameUri    String?

  /// User's text hint: "hail damage" / "these are 3-tab not architectural"
  userHint String @db.Text

  /// Assessment type used for the teach prompt (EXTERIOR, INTERIOR, DRONE_ROOF, TARGETED)
  assessmentType String @default("TARGETED")

  /// AI's refined analysis result
  aiRefinedFinding Json? /// Structured finding JSON from Gemini
  aiRawResponse    String? @db.Text /// Raw Gemini response for audit

  /// Google Search sources Gemini referenced during grounded analysis
  webSourcesUsed Json? /// Array of { url, title, snippet }

  /// User confirmation: did the refined finding accurately capture what they saw?
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?

  /// If the user corrected the AI's refined output, what did they change?
  userCorrectionJson Json? /// { field: "zone", from: "ROOF", to: "SIDING" }

  createdById String
  createdAt   DateTime @default(now())

  company    Company         @relation(fields: [companyId], references: [id])
  assessment VideoAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("TeachingExampleCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, confirmed], map: "AssessmentTeaching_company_confirmed_idx")
  @@index([assessmentId], map: "AssessmentTeaching_assessment_idx")
  @@index([companyId, assessmentType], map: "AssessmentTeaching_company_type_idx")
}

// ===================================================================
// Nex-LevelIntelligence (NLI) — Device Fleet, Watch Folders, File
// Scanning & Sync Queue. Extends ScanNEX patterns to desktop.
// ===================================================================

enum NliDeviceStatus {
  ONLINE
  OFFLINE
  SYNCING
}

enum NliDevicePlatform {
  MACOS
  WINDOWS
  LINUX
}

enum NliScannedFileStatus {
  DISCOVERED
  QUEUED
  PROCESSING
  SYNCED
  SKIPPED
  ERROR
}

enum NliSyncJobType {
  VIDEO_ASSESSMENT
  FILE_UPLOAD
  DOCUMENT_SCAN
  PHOTO_CATALOG
  BATCH_IMPORT
}

enum NliSyncJobStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

/// A registered NexBRIDGE Connect installation. Each physical device that
/// runs the desktop app registers itself with the tenant. Device
/// capabilities (FFmpeg version, disk space, OS) are reported at heartbeat.
model NliDevice {
  id        String @id @default(cuid())
  companyId String
  userId    String /// User who registered/owns this device

  deviceName String /// User-provided or hostname (e.g. "Paul's MacBook")
  platform   NliDevicePlatform
  osVersion  String? /// e.g. "macOS 15.3", "Windows 11 23H2"
  arch       String? /// e.g. "arm64", "x86_64"
  appVersion String? /// NexBRIDGE Connect version

  status     NliDeviceStatus @default(OFFLINE)
  lastSeenAt DateTime?

  /// Capability reporting (updated at heartbeat)
  ffmpegVersion         String?
  storageAvailableBytes BigInt?
  storageTotalBytes     BigInt?

  /// Auth fingerprint — unique per installation to prevent duplicates
  installId String @unique

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  registeredBy     User              @relation("NliDeviceRegisteredBy", fields: [userId], references: [id])
  watchFolders     NliWatchFolder[]
  scannedFiles     NliScannedFile[]
  syncJobs         NliSyncJob[]
  videoAssessments VideoAssessment[]

  @@index([companyId, status], map: "NliDevice_company_status_idx")
  @@index([companyId, userId], map: "NliDevice_company_user_idx")
}

/// A monitored directory on a registered device. NexBRIDGE Connect watches
/// this folder for new video, photo, and document files. When new files
/// appear they are cataloged as NliScannedFile and optionally auto-processed.
model NliWatchFolder {
  id        String @id @default(cuid())
  deviceId  String
  companyId String

  folderPath String /// Absolute path on the device (e.g. "/Users/pg/NexBRIDGE/Inbox")
  label      String? /// Friendly name (e.g. "Drone SD Card", "Desktop Drop Zone")

  /// Processing flags — what should NexBRIDGE do with new files?
  autoProcessVideo Boolean @default(true)
  autoProcessPhoto Boolean @default(false)
  autoUploadDocs   Boolean @default(false)

  /// Optional auto-assignment: files from this folder → this project
  projectId String?

  active     Boolean   @default(true)
  lastScanAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  device       NliDevice        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  company      Company          @relation(fields: [companyId], references: [id])
  scannedFiles NliScannedFile[]

  @@index([deviceId], map: "NliWatchFolder_device_idx")
  @@index([companyId, active], map: "NliWatchFolder_company_active_idx")
}

/// A file discovered locally on a device, either through a watch folder
/// or via manual scan / drag-and-drop. Tracks the full lifecycle from
/// discovery through processing to sync. Stores a file hash for
/// deduplication — won't re-process the same footage twice.
model NliScannedFile {
  id            String  @id @default(cuid())
  deviceId      String
  companyId     String
  watchFolderId String? /// null if added manually (not from watch folder)
  projectId     String? /// auto-assigned from watch folder, or manual

  filePath      String /// Absolute path on device
  fileName      String
  fileSizeBytes BigInt
  mimeType      String? /// e.g. "video/mp4", "image/jpeg", "application/pdf"
  fileHash      String? /// SHA-256 for deduplication

  status       NliScannedFileStatus @default(DISCOVERED)
  errorMessage String?

  /// Output linkage — what did processing produce?
  videoAssessmentId String? /// If this file was processed as a video assessment

  discoveredAt DateTime  @default(now())
  processedAt  DateTime?
  syncedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  device           NliDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  company          Company           @relation(fields: [companyId], references: [id])
  watchFolder      NliWatchFolder?   @relation(fields: [watchFolderId], references: [id], onDelete: SetNull)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  videoAssessments VideoAssessment[]
  syncJobs         NliSyncJob[]

  @@unique([deviceId, fileHash], name: "NliScannedFile_device_hash_key")
  @@index([companyId, status], map: "NliScannedFile_company_status_idx")
  @@index([deviceId, status], map: "NliScannedFile_device_status_idx")
  @@index([companyId, projectId], map: "NliScannedFile_company_project_idx")
}

/// An offline-capable sync operation. Jobs are queued on the device and
/// executed when connectivity is available. Mirrors ScanNEX's proven
/// WiFi-background-sync pattern (JSON first, media last).
model NliSyncJob {
  id        String  @id @default(cuid())
  deviceId  String
  companyId String
  projectId String?

  type     NliSyncJobType
  status   NliSyncJobStatus @default(QUEUED)
  priority Int              @default(0) /// Higher = process first

  /// What to sync (request payload, stored as JSON)
  scannedFileId String?
  payloadJson   Json? /// Flexible payload per job type

  /// Result tracking
  resultJson   Json? /// Response/output from the operation
  errorMessage String? /// Error details if status = FAILED
  retryCount   Int     @default(0)
  maxRetries   Int     @default(3)

  createdById String
  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  device      NliDevice       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  company     Company         @relation(fields: [companyId], references: [id])
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  scannedFile NliScannedFile? @relation(fields: [scannedFileId], references: [id], onDelete: SetNull)
  createdBy   User            @relation("NliSyncJobCreatedBy", fields: [createdById], references: [id])

  @@index([deviceId, status], map: "NliSyncJob_device_status_idx")
  @@index([companyId, status], map: "NliSyncJob_company_status_idx")
  @@index([companyId, type], map: "NliSyncJob_company_type_idx")
}

// =============================================================================
// Agreements & Contracts System
// =============================================================================

enum AgreementCategory {
  CONTINGENCY
  SUBCONTRACT
  CHANGE_ORDER
  SERVICE
  NDA
  WORK_AUTHORIZATION
  OTHER
}

enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURES
  PARTIALLY_SIGNED
  FULLY_EXECUTED
  VOIDED
  EXPIRED
}

enum SignatoryRole {
  CLIENT
  CLIENT_2
  COMPANY_REP
  CEO
  WITNESS
  SUBCONTRACTOR
  OTHER
}

enum SignatureMethod {
  TYPED // Typed full name as signature
  DRAWN // Canvas-drawn signature (stored as base64 PNG)
  UPLOADED // Uploaded image of signature
}

enum AgreementAuditAction {
  CREATED
  UPDATED
  VARIABLES_FILLED
  SENT_FOR_SIGNATURES
  VIEWED
  SIGNED
  VOIDED
  EXPIRED
  DOWNLOADED_PDF
}

enum TemplateSourceType {
  MANUAL // Created from scratch in the builder
  IMPORTED_DOCX // Uploaded DOCX converted via mammoth
  IMPORTED_PDF // Uploaded PDF converted to HTML or page images
  IMPORTED_IMAGE // Scanned document / image (overlay mode)
  IMPORTED_HTML // Uploaded HTML file
}

/// Master template for agreements. companyId=null means system-level (available
/// to all tenants). companyId set means tenant-created custom template.
model AgreementTemplate {
  id              String             @id @default(cuid())
  companyId       String? // null = system-level template
  code            String // e.g. "FL-CONTINGENCY-001"
  title           String
  description     String?
  jurisdiction    String? // e.g. "FL", "TX", null for non-state-specific
  category        AgreementCategory  @default(OTHER)
  htmlContent     String             @db.Text
  variables       Json? // Array of { key, label, type, required, group }
  isActive        Boolean            @default(true)
  currentVersion  Int                @default(1)
  sourceType      TemplateSourceType @default(MANUAL)
  originalFileUrl String? // GCS path to uploaded source file
  overlayFields   Json? // For overlay mode: [{ key, label, type, x, y, width, height, pageIndex }]
  pageImageUrls   Json? // For overlay mode: ["url1", "url2", ...] per-page image URLs
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  company    Company?                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?                      @relation("AgreementTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  agreements Agreement[]
  versions   AgreementTemplateVersion[]

  @@unique([companyId, code], name: "AgreementTemplate_company_code_key")
  @@index([companyId, isActive], map: "AgreementTemplate_company_active_idx")
  @@index([category], map: "AgreementTemplate_category_idx")
}

/// Historical version snapshot of an agreement template. Created automatically
/// whenever the template HTML or variables are updated.
model AgreementTemplateVersion {
  id              String   @id @default(cuid())
  templateId      String
  versionNo       Int
  htmlContent     String   @db.Text
  variables       Json? // Snapshot of variables at this version
  overlayFields   Json? // Snapshot of overlay fields at this version
  changeNote      String? // Optional description of what changed
  changedByUserId String?
  createdAt       DateTime @default(now())

  template  AgreementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  changedBy User?             @relation("AgreementTemplateVersionChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@unique([templateId, versionNo], name: "AgreementTemplateVersion_template_version_key")
  @@index([templateId, createdAt], map: "AgreementTemplateVersion_template_time_idx")
}

/// A concrete agreement instance created from a template (or blank).
model Agreement {
  id              String          @id @default(cuid())
  companyId       String
  templateId      String?
  projectId       String?
  title           String
  agreementNumber String // Auto-generated, e.g. "AGR-2026-0001"
  status          AgreementStatus @default(DRAFT)
  htmlContent     String?         @db.Text // Rendered HTML with variables filled
  variables       Json? // Filled variable values { key: value }
  dueDate         DateTime?
  sentAt          DateTime? // When sent for signatures
  fullyExecutedAt DateTime? // When all signatures collected
  voidedAt        DateTime?
  voidReason      String?
  createdByUserId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template    AgreementTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy   User                 @relation("AgreementCreatedBy", fields: [createdByUserId], references: [id])
  signatories AgreementSignatory[]
  auditLog    AgreementAuditLog[]

  @@unique([companyId, agreementNumber], name: "Agreement_company_number_key")
  @@index([companyId, status], map: "Agreement_company_status_idx")
  @@index([companyId, projectId], map: "Agreement_company_project_idx")
  @@index([templateId], map: "Agreement_template_idx")
}

/// A person who must sign (or has signed) an agreement.
model AgreementSignatory {
  id              String           @id @default(cuid())
  agreementId     String
  role            SignatoryRole    @default(CLIENT)
  name            String
  email           String?
  phone           String?
  signedAt        DateTime?
  signatureData   String?          @db.Text // base64 image or typed name
  signatureMethod SignatureMethod?
  signatureToken  String?          @unique // Unique token for email-based signing links
  ipAddress       String?
  userAgent       String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId, role], map: "AgreementSignatory_agreement_role_idx")
  @@index([signatureToken], map: "AgreementSignatory_token_idx")
}

/// Immutable audit trail for every action on an agreement.
model AgreementAuditLog {
  id          String               @id @default(cuid())
  agreementId String
  action      AgreementAuditAction
  actorUserId String?
  actorName   String?
  metadata    Json? // Additional context per action
  ipAddress   String?
  createdAt   DateTime             @default(now())

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId, createdAt], map: "AgreementAuditLog_agreement_time_idx")
}

// =============================================================================
// NexCheck — Site Compliance Kiosk System
// =============================================================================

enum SiteDocCategory {
  JSA
  ONBOARDING
  SAFETY
  POLICY
  CUSTOM
}

enum SiteDocFrequency {
  ONCE // First visit only
  DAILY // Every day
  ON_CHANGE // Re-acknowledge when document version changes
}

enum SignOutMethod {
  MANUAL // Worker signed out at kiosk
  SYSTEM_AUTO_SIGNOUT // Geo-fence departure, grace period expired
  SYSTEM_EOD_SIGNOUT // End-of-day cutoff, no departure detected
}

/// Unique site pass token for a person (Nexus user or external visitor).
/// The raw token lives on the device; only the SHA-256 hash is stored here.
model SitePass {
  id          String    @id @default(cuid())
  companyId   String
  userId      String? // Null for external visitors
  workerId    String? // Null until linked to a Worker record
  tokenHash   String    @unique // SHA-256 of the raw 32-byte token
  displayName String
  companyName String? // Visitor's company name (not the tenant)
  trade       String?
  phone       String?
  email       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  worker   Worker?           @relation(fields: [workerId], references: [id], onDelete: SetNull)
  checkIns SiteCheckIn[]
  acks     SiteDocumentAck[]

  @@index([companyId], map: "SitePass_company_idx")
  @@index([userId], map: "SitePass_user_idx")
  @@index([workerId], map: "SitePass_worker_idx")
}

/// A document that workers must acknowledge at a project site.
/// PMs configure which documents are required per project.
model SiteDocument {
  id              String           @id @default(cuid())
  companyId       String
  projectId       String
  title           String
  htmlContent     String           @db.Text
  category        SiteDocCategory  @default(CUSTOM)
  frequency       SiteDocFrequency @default(DAILY)
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  version         Int              @default(1)
  sourceDocId     String? // Optional link to TenantPnpDocument
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?             @relation("SiteDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  acks      SiteDocumentAck[]

  @@index([companyId, projectId], map: "SiteDocument_company_project_idx")
  @@index([projectId, isActive], map: "SiteDocument_project_active_idx")
}

/// Record of a worker acknowledging a specific site document during check-in.
model SiteDocumentAck {
  id               String   @id @default(cuid())
  siteDocumentId   String
  sitePassId       String
  projectId        String
  documentVersion  Int // Version of the document at time of ack
  checkInSessionId String // Links to the SiteCheckIn session
  acknowledgedAt   DateTime @default(now())

  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)
  sitePass     SitePass     @relation(fields: [sitePassId], references: [id], onDelete: Cascade)
  checkIn      SiteCheckIn  @relation(fields: [checkInSessionId], references: [id], onDelete: Cascade)

  @@index([siteDocumentId, sitePassId], map: "SiteDocumentAck_doc_pass_idx")
  @@index([sitePassId, acknowledgedAt], map: "SiteDocumentAck_pass_time_idx")
  @@index([checkInSessionId], map: "SiteDocumentAck_checkin_idx")
}

/// A single check-in session at a project site. Tracks identity confirmation,
/// document acknowledgments, signature, and sign-out.
model SiteCheckIn {
  id             String         @id @default(cuid())
  companyId      String
  projectId      String
  sitePassId     String
  kioskSessionId String? // Null if checked in via personal device
  checkInAt      DateTime       @default(now())
  signOutAt      DateTime?
  signOutMethod  SignOutMethod?
  signatureSvg   String?        @db.Text // SVG path data from finger signature
  documentsAcked Int            @default(0)
  createdAt      DateTime       @default(now())

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sitePass     SitePass          @relation(fields: [sitePassId], references: [id], onDelete: Cascade)
  kioskSession KioskSession?     @relation(fields: [kioskSessionId], references: [id], onDelete: SetNull)
  acks         SiteDocumentAck[]

  @@index([companyId, projectId, checkInAt], map: "SiteCheckIn_company_project_time_idx")
  @@index([sitePassId, checkInAt], map: "SiteCheckIn_pass_time_idx")
  @@index([kioskSessionId], map: "SiteCheckIn_kiosk_idx")
  @@index([projectId, checkInAt], map: "SiteCheckIn_project_time_idx")
}

/// Tracks an active kiosk session on a device. A device in kiosk mode is
/// bound to a single project and records all check-ins through it.
model KioskSession {
  id                String    @id @default(cuid())
  companyId         String
  projectId         String
  deviceId          String // Unique device fingerprint
  activatedByUserId String
  isActive          Boolean   @default(true)
  activatedAt       DateTime  @default(now())
  deactivatedAt     DateTime?

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activatedBy User          @relation("KioskSessionActivatedBy", fields: [activatedByUserId], references: [id])
  checkIns    SiteCheckIn[]

  @@index([companyId, projectId], map: "KioskSession_company_project_idx")
  @@index([deviceId, isActive], map: "KioskSession_device_active_idx")
}

/// Time-boxed delegation of kiosk activation rights from a PM/admin to a
/// field user (typically a foreman). Default 24h, max 7 days.
model KioskDelegation {
  id                String    @id @default(cuid())
  companyId         String
  projectId         String
  delegatedToUserId String
  delegatedByUserId String
  expiresAt         DateTime // Default: now + 24h, max: now + 7d
  revokedAt         DateTime? // Set if PM revokes early
  createdAt         DateTime  @default(now())

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  delegatedTo User    @relation("KioskDelegationReceivedBy", fields: [delegatedToUserId], references: [id])
  delegatedBy User    @relation("KioskDelegationGrantedBy", fields: [delegatedByUserId], references: [id])

  @@index([companyId, projectId], map: "KioskDelegation_company_project_idx")
  @@index([delegatedToUserId, expiresAt], map: "KioskDelegation_delegate_expiry_idx")
}

// ===================================================================
// Purchase Reconciliation — CC-to-Checking Audit Chain
// ===================================================================

/// Links a checking account outflow (payment to CC company) to individual
/// credit card charges it covers. Enables the audit trail:
/// Checking outflow → CC charges → Receipt line items → Project costs.
model CreditCardPaymentLink {
  id              String              @id @default(cuid())
  companyId       String
  checkingTxnId   String // BankTransaction.id (the checking outflow)
  creditCardTxnId String // ImportedTransaction.id (individual CC charge)
  status          CcPaymentLinkStatus @default(SUGGESTED)
  confidence      Float? // 0.0–1.0 match confidence
  linkedByUserId  String?
  linkedAt        DateTime?
  createdAt       DateTime            @default(now())

  company       Company             @relation(fields: [companyId], references: [id])
  checkingTxn   BankTransaction     @relation(fields: [checkingTxnId], references: [id])
  creditCardTxn ImportedTransaction @relation(fields: [creditCardTxnId], references: [id])
  linkedBy      User?               @relation("CcPaymentLinkLinkedBy", fields: [linkedByUserId], references: [id])

  @@unique([companyId, creditCardTxnId], name: "CreditCardPaymentLink_company_ccTxn_key")
  @@index([companyId, checkingTxnId], map: "CreditCardPaymentLink_company_checking_idx")
  @@index([companyId, status], map: "CreditCardPaymentLink_company_status_idx")
}

/// Per-line-item disposition from OCR receipts. Structured, auditable record
/// replacing the bulk excludedLineItemsJson. Each receipt line item can be
/// kept on job, credited (personal), or moved to another project.
model ReceiptLineDisposition {
  id                    String          @id @default(cuid())
  companyId             String
  dailyLogId            String
  ocrResultId           String
  lineItemIndex         Int // Position in the OCR lineItemsJson array
  description           String? // Snapshot from OCR
  amount                Float? // Snapshot from OCR
  sourceProjectId       String // Project from the daily log
  dispositionType       DispositionType
  targetProjectId       String? // If MOVE_TO_PROJECT
  creditReason          String? // If CREDIT_PERSONAL
  dispositionedByUserId String?
  dispositionedAt       DateTime        @default(now())
  createdAt             DateTime        @default(now())

  company         Company          @relation(fields: [companyId], references: [id])
  dailyLog        DailyLog         @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  ocrResult       ReceiptOcrResult @relation(fields: [ocrResultId], references: [id], onDelete: Cascade)
  sourceProject   Project          @relation("ReceiptLineDispositionSource", fields: [sourceProjectId], references: [id])
  targetProject   Project?         @relation("ReceiptLineDispositionTarget", fields: [targetProjectId], references: [id])
  dispositionedBy User?            @relation("ReceiptLineDispositionBy", fields: [dispositionedByUserId], references: [id])

  @@unique([ocrResultId, lineItemIndex], name: "ReceiptLineDisposition_ocr_lineItem_key")
  @@index([companyId, dailyLogId], map: "ReceiptLineDisposition_company_dailyLog_idx")
}

/// PM reconciliation review queue. Transactions pushed to a project
/// require PM confirmation before being marked as CONFIRMED.
model PmReviewItem {
  id                 String                  @id @default(cuid())
  companyId          String
  projectId          String
  transactionType    PmReviewTransactionType
  transactionId      String // Polymorphic: ImportedTransaction, BankTransaction, or ReceiptLineDisposition ID
  assignedToUserId   String // Project PM
  status             PmReviewStatus          @default(PENDING)
  suggestedAmount    Float?
  suggestedProjectId String? // What the system suggested
  reviewNote         String?
  reviewedAt         DateTime?
  reviewedByUserId   String?
  createdAt          DateTime                @default(now())

  company    Company @relation(fields: [companyId], references: [id])
  project    Project @relation(fields: [projectId], references: [id])
  assignedTo User    @relation("PmReviewAssignedTo", fields: [assignedToUserId], references: [id])
  reviewedBy User?   @relation("PmReviewReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([companyId, projectId, status], map: "PmReviewItem_company_project_status_idx")
  @@index([assignedToUserId, status], map: "PmReviewItem_assignee_status_idx")
}

// ===================================================================
// Bill Sibling Groups — Duplicate Detection & Verification Offset
// ===================================================================

/// Groups bills that represent the same economic event from multiple sources
/// (e.g., OCR receipt + CC transaction). One bill is PRIMARY (source of truth),
/// others are VERIFICATION (net to $0 via DUPLICATE_OFFSET line items).
model BillSiblingGroup {
  id                 String                 @id @default(cuid())
  companyId          String
  projectId          String
  primaryBillId      String? // The source-of-truth bill (typically OCR receipt)
  matchConfidence    Float? // 0.0–1.0 duplicate detection confidence
  matchReason        String? // Human-readable: "Vendor: Home Depot, Amount: $485.23 ±$0.00, Date: ±1 day"
  verificationStatus BillVerificationStatus @default(PENDING_VERIFICATION)
  amountVariance     Float? // Absolute $ difference between primary and verification amounts
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bills   ProjectBill[]

  @@index([companyId, projectId], map: "BillSiblingGroup_company_project_idx")
  @@index([companyId, verificationStatus], map: "BillSiblingGroup_company_status_idx")
}

// ===================================================================
// NexPRICE — Regional Pricing Intelligence
// ===================================================================

/// Cost-of-living index lookup table for NexPRICE regional normalization.
/// Maps geographic regions to COL multipliers (NYC = 100 as base).
model RegionalCostIndex {
  id            String     @id @default(cuid())
  regionCode    String // ZIP3 prefix, metro code, state code, or country code
  regionName    String // Human-readable: "Houston Metro", "NYC", "Rural Alabama"
  regionType    RegionType
  costIndex     Float // Raw COL index value (NYC = 100)
  multiplier    Float // Precomputed costIndex / 100 (e.g., 0.82 for Houston)
  source        String? // "C2ER", "NUMBEO", "BLS", "MANUAL"
  effectiveYear Int // Year this index applies to (refresh annually)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([regionCode, effectiveYear], name: "RegionalCostIndex_region_year_key")
  @@index([regionType, regionCode], map: "RegionalCostIndex_type_code_idx")
}

/// Home Depot store location lookup for NexPRICE region resolution.
/// Maps HD store numbers to physical ZIP codes for regional pricing.
model HdStoreLocation {
  id          String   @id @default(cuid())
  storeNumber String   @unique // e.g., "0604", "6528"
  zip         String
  city        String?
  state       String?
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  @@index([zip], map: "HdStoreLocation_zip_idx")
}

// =============================================================================
// Remote Support — Screen Sharing & Remote Control
// =============================================================================

/// Trouble ticket that gates screen sharing sessions. A client creates a ticket;
/// a support agent is assigned and can initiate a screen share session.
model SupportTicket {
  id           String                @id @default(cuid())
  companyId    String
  createdById  String
  assignedToId String?
  status       SupportTicketStatus   @default(OPEN)
  priority     SupportTicketPriority @default(MEDIUM)
  subject      String
  description  String?               @db.Text
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  resolvedAt   DateTime?

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User             @relation("SupportTicketCreatedBy", fields: [createdById], references: [id])
  assignedTo User?            @relation("SupportTicketAssignedTo", fields: [assignedToId], references: [id])
  sessions   SupportSession[]

  @@index([companyId, status, createdAt], map: "SupportTicket_company_status_created_idx")
  @@index([assignedToId, status], map: "SupportTicket_assignee_status_idx")
  @@index([createdById, createdAt], map: "SupportTicket_creator_created_idx")
}

/// A screen sharing session tied to a support ticket. The sessionCode is a
/// short, unique, one-time code used by both parties to join the WebRTC
/// signaling channel. Sessions expire after 30 min of inactivity.
model SupportSession {
  id            String               @id @default(cuid())
  ticketId      String
  sessionCode   String               @unique // 6-char alphanumeric, used to join
  status        SupportSessionStatus @default(PENDING)
  mode          SupportSessionMode   @default(VIEW_ONLY)
  clientUserId  String
  agentUserId   String?
  clientIp      String?
  agentIp       String?
  startedAt     DateTime?
  endedAt       DateTime?
  lastHeartbeat DateTime?
  createdAt     DateTime             @default(now())

  ticket     SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  clientUser User                  @relation("SupportSessionClient", fields: [clientUserId], references: [id])
  agentUser  User?                 @relation("SupportSessionAgent", fields: [agentUserId], references: [id])
  events     SupportSessionEvent[]

  @@index([ticketId], map: "SupportSession_ticket_idx")
  @@index([sessionCode], map: "SupportSession_code_idx")
  @@index([status, lastHeartbeat], map: "SupportSession_status_heartbeat_idx")
}

/// Immutable audit trail for every significant event during a support session.
model SupportSessionEvent {
  id          String                  @id @default(cuid())
  sessionId   String
  eventType   SupportSessionEventType
  actorUserId String?
  metadata    Json?
  createdAt   DateTime                @default(now())

  session   SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actorUser User?          @relation("SupportSessionEventActor", fields: [actorUserId], references: [id])

  @@index([sessionId, createdAt], map: "SupportSessionEvent_session_created_idx")
}

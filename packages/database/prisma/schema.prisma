}

model AssetTagAssignment {
  id         String   @id @default(cuid())
  assetId    String
  tagId      String
  assignedAt DateTime @default(now())

  asset Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   AssetTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagId], map: "AssetTagAssignment_asset_tag_key")
  @@index([assetId])
  @@index([tagId])
}

model Asset {
  id              String    @id @default(cuid())
  companyId       String
  name            String
  code            String?
  description     String?
  assetType       AssetType
  baseUnit        String?
  baseRate        Decimal?  @db.Decimal(12, 4)
  costBreakdown   Json?
  attributes      Json?
  isTrackable     Boolean   @default(false)
  isConsumable    Boolean   @default(false)
  priceListItemId String?

  // Disposition (replaces blunt isActive for richer status)
  dispositionId String?
  disposition   AssetDisposition? @relation(fields: [dispositionId], references: [id])

  // Identity / OEM
  manufacturer      String?
  model             String?
  serialNumberOrVin String?
  year              Int?
  isActive          Boolean @default(true) /// Derived from disposition.isTerminal

  // Ownership & sharing
  ownershipType     AssetOwnershipType     @default(COMPANY)
  ownerId           String?
  owner             User?                  @relation("AssetOwner", fields: [ownerId], references: [id])
  sharingVisibility AssetSharingVisibility @default(COMPANY)
  shareGrants       AssetShareGrant[]

  // Rental offering (personal assets offered to company pool)
  availableForRent   Boolean   @default(false)
  rentalDailyRate    Decimal?  @db.Decimal(12, 4)
  rentalNotes        String?
  offeredAt          DateTime?
  offeredToCompanyId String?

  // Maintenance assignment
  maintenanceAssigneeId String?
  maintenanceAssignee   User?            @relation("AssetMaintenanceAssignee", fields: [maintenanceAssigneeId], references: [id])
  maintenancePoolId     String?
  maintenancePool       MaintenancePool? @relation(fields: [maintenancePoolId], references: [id])

  // Maintenance configuration (per asset)
  maintenanceProfileCode   String?
  maintTriggerStrategy     MaintenanceTriggerStrategy?
  maintTimeIntervalValue   Int?
  maintTimeIntervalUnit    MaintenanceIntervalUnit?
  maintMeterType           MaintenanceMeterType?
  maintMeterIntervalAmount Int?
  maintLeadTimeDays        Int?
  maintNotes               String?
  maintOwnerEmail          String?
  maintOwnerExternalId     String?

  // Location-aware field (optional initially)
  currentLocationId String?
  currentLocation   Location? @relation("AssetCurrentLocation", fields: [currentLocationId], references: [id])

  // Asset Scanner — template & 3D capture fields
  isTemplate       Boolean @default(false) /// Canonical product reference (not a physical unit)
  templateAssetId  String? /// FK → Asset (self-ref). Created-from template link.
  scanModelUrl     String? /// GCS URL to USDZ 3D model from Object Capture
  scanThumbnailUrl String? /// GCS URL to preview image of the 3D scan
  dimensions       Json? /// { length, width, height, unit: "in"|"cm"|"m" }
  tagPhotoUrl      String? /// GCS URL to nameplate/serial plate photo

  templateAsset Asset?  @relation("AssetTemplate", fields: [templateAssetId], references: [id])
  fleetMembers  Asset[] @relation("AssetTemplate")

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  company       Company            @relation(fields: [companyId], references: [id])
  priceListItem PriceListItem?     @relation(fields: [priceListItemId], references: [id])
  usages        AssetUsage[]
  transactions  AssetTransaction[]
  scans         AssetScan[]

  // Tags
  tagAssignments AssetTagAssignment[]

  // Attachments (files stored in MinIO)
  attachments AssetAttachment[]

  // Maintenance relations
  maintenanceSchedules AssetMaintenanceSchedule[]
  maintenanceTodos     MaintenanceTodo[]
  meterReadings        AssetMeterReading[]
  placards             AssetPlacard[]

  @@index([companyId, assetType], map: "Asset_company_type_idx")
  @@index([companyId, currentLocationId])
  @@index([companyId, dispositionId])
  @@index([ownerId])
  @@index([maintenancePoolId])
  @@index([templateAssetId], map: "Asset_template_idx")
}

model AssetUsage {
  id                    String             @id @default(cuid())
  assetId               String
  companyId             String
  projectId             String
  sowItemId             String?
  dailyLogId            String?
  billingMode           BillingMode
  status                UsageStatus        @default(PLANNED)
  quantity              Decimal?           @db.Decimal(12, 4)
  unit                  String?
  overrideRate          Decimal?           @db.Decimal(12, 4)
  snapshotRate          Decimal?           @db.Decimal(12, 4)
  snapshotCostBreakdown Json?
  actualCost            Decimal?           @db.Decimal(14, 2)
  startDate             DateTime?
  endDate               DateTime?
  notes                 String?
  createdByUserId       String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  asset                 Asset              @relation(fields: [assetId], references: [id])
  company               Company            @relation(fields: [companyId], references: [id])
  project               Project            @relation(fields: [projectId], references: [id])
  sowItem               SowItem?           @relation(fields: [sowItemId], references: [id])
  dailyLog              DailyLog?          @relation(fields: [dailyLogId], references: [id])
  createdBy             User?              @relation(fields: [createdByUserId], references: [id])
  transactions          AssetTransaction[]

  @@index([companyId, projectId], map: "AssetUsage_company_project_idx")
  @@index([assetId, status], map: "AssetUsage_asset_status_idx")
}

model AssetTransaction {
  id          String          @id @default(cuid())
  assetId     String
  companyId   String
  projectId   String?
  usageId     String?
  kind        TransactionKind
  quantity    Decimal?        @db.Decimal(12, 4)
  unit        String?
  unitCost    Decimal?        @db.Decimal(12, 4)
  totalCost   Decimal?        @db.Decimal(14, 2)
  notes       String?
  createdById String?
  createdAt   DateTime        @default(now())
  asset       Asset           @relation(fields: [assetId], references: [id])
  company     Company         @relation(fields: [companyId], references: [id])
  project     Project?        @relation(fields: [projectId], references: [id])
  usage       AssetUsage?     @relation(fields: [usageId], references: [id])
  createdBy   User?           @relation(fields: [createdById], references: [id])

  @@index([companyId, createdAt], map: "AssetTransaction_company_created_idx")
  @@index([assetId, createdAt], map: "AssetTransaction_asset_created_idx")
}

enum AssetType {
  LABOR
  MATERIAL
  EQUIPMENT
  TOOL
  RENTAL
  OTHER
}

enum BillingMode {
  TIME_AND_MATERIAL
  FIXED_FEE
  INCLUDED_IN_SCOPE
  NO_CHARGE
}

enum UsageStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELED
}

enum TransactionKind {
  PURCHASE
  CONSUME
  TRANSFER
  RETURN
  WASTE
  TIME_PUNCH
  MAINTENANCE
  ADJUSTMENT
}

enum AssetAttachmentCategory {
  PHOTO
  TITLE
  INSURANCE
  MANUAL
  RECEIPT
  DIAGNOSTIC
  CONTRACT
  WARRANTY
  SCHEMATIC
  OTHER
}

model AssetAttachment {
  id               String                  @id @default(cuid())
  companyId        String
  assetId          String
  fileName         String
  fileType         String? /// MIME type
  fileSize         Int /// Bytes
  storageKey       String /// MinIO key: asset-attachments/{companyId}/{assetId}/{timestamp}-{filename}
  category         AssetAttachmentCategory @default(OTHER)
  notes            String?
  uploadedByUserId String?
  createdAt        DateTime                @default(now())

  company    Company @relation(fields: [companyId], references: [id])
  asset      Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("AssetAttachmentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([companyId, assetId], map: "AssetAttachment_company_asset_idx")
}

enum PlacardStatus {
  ACTIVE
  VOID
  LOST
}

/// Nex-Plac QR placard assigned to a physical asset.
/// The QR payload contains a signed URI for instant, tamper-proof identification.
model AssetPlacard {
  id               String        @id @default(cuid())
  companyId        String
  assetId          String
  code             String /// Human-readable serial e.g. NP-000123
  qrPayload        String /// Full signed URI: nexplac://a/<assetId>?co=<companyId>&sig=<hmac>
  status           PlacardStatus @default(ACTIVE)
  assignedAt       DateTime      @default(now())
  assignedByUserId String
  voidedAt         DateTime?
  voidedByUserId   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company    Company @relation(fields: [companyId], references: [id])
  asset      Asset   @relation(fields: [assetId], references: [id])
  assignedBy User    @relation("PlacardAssignedBy", fields: [assignedByUserId], references: [id])
  voidedBy   User?   @relation("PlacardVoidedBy", fields: [voidedByUserId], references: [id])

  @@unique([companyId, code], map: "AssetPlacard_company_code_key")
  @@index([companyId, assetId], map: "AssetPlacard_company_asset_idx")
  @@index([companyId, status], map: "AssetPlacard_company_status_idx")
}

/// Per-company atomic counter for placard serial numbers.
model PlacardCounter {
  id         String @id @default(cuid())
  companyId  String @unique
  nextSerial Int    @default(1)

  company Company @relation(fields: [companyId], references: [id])
}

enum MaintenanceTriggerStrategy {
  TIME_ONLY
  METER_ONLY
  TIME_OR_METER
}

enum MaintenanceIntervalUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum MaintenanceMeterType {
  HOURS
  MILES
  RUN_CYCLES
  GENERATOR_HOURS
}

enum MaintenanceTodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  CANCELLED
}

enum AssetOwnershipType {
  COMPANY
  PERSONAL
}

enum AssetSharingVisibility {
  PRIVATE
  COMPANY
  CUSTOM
}

enum DeviceLicenseType {
  CLOUD_SUBSCRIPTION
  STANDALONE
  STANDALONE_WITH_UPDATES
  EXPIRED
}

model Location {
  id        String       @id @default(cuid())
  companyId String
  type      LocationType
  name      String
  code      String?

  parentLocationId String?
  parent           Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  children         Location[] @relation("LocationHierarchy")

  latitude  Float?
  longitude Float?

  isActive Boolean @default(true)
  metadata Json?

  company Company @relation(fields: [companyId], references: [id])

  currentAssets       Asset[]             @relation("AssetCurrentLocation")
  currentMaterialLots MaterialLot[]       @relation("MaterialLotCurrentLocation")
  originMaterialLots  MaterialLot[]       @relation("MaterialLotOriginLocation")
  currentParticles    InventoryParticle[] @relation("InventoryParticleCurrentLocation")
  virtualParticles    InventoryParticle[] @relation("InventoryParticleVirtualLocation")

  movementsFrom InventoryMovement[] @relation("InventoryMovementFromLocation")
  movementsTo   InventoryMovement[] @relation("InventoryMovementToLocation")

  inventoryPositions InventoryPosition[]

  // People assigned to this physical/virtual location.
  personLocations PersonLocation[]

  // Daily log references (origin location, move from/to)
  dailyLogOrigins  DailyLog[] @relation("DailyLogOriginLocation")
  dailyLogMoveFrom DailyLog[] @relation("DailyLogMoveFromLocation")
  dailyLogMoveTo   DailyLog[] @relation("DailyLogMoveToLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code], name: "Location_companyId_code_unique")
  @@index([companyId, type])
}

model PersonLocation {
  id         String @id @default(cuid())
  companyId  String
  userId     String
  locationId String

  company  Company  @relation(fields: [companyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([companyId, userId], name: "PersonLocation_companyId_userId_unique")
}

model MaterialLot {
  id        String @id @default(cuid())
  companyId String

  sku      String
  name     String
  quantity Decimal @db.Decimal(18, 4)
  uom      String

  currentLocationId String
  currentLocation   Location @relation("MaterialLotCurrentLocation", fields: [currentLocationId], references: [id])

  /// Provenance tracking for receipt-to-inventory pipeline
  originLocationId     String? // FK → Location (vendor/store where purchased)
  sourceDailyLogId     String? // FK → DailyLog (receipt that created this lot)
  destinationProjectId String? // FK → Project (which project materials are intended for)
  lotKey               String? // Computed: "{originLocationCode}:{sku}" for matching

  metadata Json?

  company            Company   @relation(fields: [companyId], references: [id])
  originLocation     Location? @relation("MaterialLotOriginLocation", fields: [originLocationId], references: [id])
  sourceDailyLog     DailyLog? @relation("MaterialLotSourceDailyLog", fields: [sourceDailyLogId], references: [id])
  destinationProject Project?  @relation("MaterialLotDestinationProject", fields: [destinationProjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, sku])
  @@index([companyId, currentLocationId])
  @@index([companyId, originLocationId], map: "MaterialLot_company_origin_location_idx")
  @@index([companyId, destinationProjectId], map: "MaterialLot_company_project_idx")
  @@index([lotKey], map: "MaterialLot_lotKey_idx")
}

model InventoryParticle {
  id        String @id @default(cuid())
  companyId String

  parentEntityType String
  parentEntityId   String

  quantity Decimal @db.Decimal(18, 4)
  uom      String

  locationId String
  location   Location @relation("InventoryParticleCurrentLocation", fields: [locationId], references: [id])

  virtualLocationId String?
  virtualLocation   Location? @relation("InventoryParticleVirtualLocation", fields: [virtualLocationId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, locationId])
  @@index([companyId, parentEntityType, parentEntityId])
}

model InventoryMovement {
  id        String @id @default(cuid())
  companyId String

  itemType InventoryItemType
  itemId   String

  fromLocationId String?
  fromLocation   Location? @relation("InventoryMovementFromLocation", fields: [fromLocationId], references: [id])

  toLocationId String
  toLocation   Location @relation("InventoryMovementToLocation", fields: [toLocationId], references: [id])

  quantity Decimal? @db.Decimal(18, 4)

  // Optional costing information associated with this movement
  metadata Json?

  transportCost     Decimal? @db.Decimal(14, 2)
  internalLaborCost Decimal? @db.Decimal(14, 2)

  movedByUserId String
  movedAt       DateTime @default(now())

  reason String
  note   String?

  company Company @relation(fields: [companyId], references: [id])
  movedBy User    @relation(fields: [movedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId, itemType, itemId])
  @@index([companyId, toLocationId, movedAt])
}

model AssetMaintenanceTemplate {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code        String
  name        String
  description String?
  assetType   AssetType?

  isActive Boolean @default(true)

  rules     AssetMaintenanceRule[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([companyId, code])
}

model AssetMaintenanceRule {
  id         String                   @id @default(cuid())
  templateId String
  template   AssetMaintenanceTemplate @relation(fields: [templateId], references: [id])

  name        String
  description String?

  triggerStrategy     MaintenanceTriggerStrategy
  timeIntervalValue   Int?
  timeIntervalUnit    MaintenanceIntervalUnit?
  meterType           MaintenanceMeterType?
  meterIntervalAmount Int?
  leadTimeDays        Int?

  defaultAssigneeRole Role?
  priority            Int?

  isActive Boolean @default(true)

  schedules AssetMaintenanceSchedule[]
  todos     MaintenanceTodo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetMaintenanceSchedule {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  ruleId String
  rule   AssetMaintenanceRule @relation(fields: [ruleId], references: [id])

  lastServiceDate  DateTime?
  lastServiceMeter Int?

  nextTimeDueAt  DateTime?
  nextMeterDueAt Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todos MaintenanceTodo[]

  @@unique([assetId, ruleId])
}

model MaintenanceTodo {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  scheduleId String?
  schedule   AssetMaintenanceSchedule? @relation(fields: [scheduleId], references: [id])

  ruleId String?
  rule   AssetMaintenanceRule? @relation(fields: [ruleId], references: [id])

  title       String
  description String?

  status            MaintenanceTodoStatus @default(PENDING)
  dueDate           DateTime?
  completedAt       DateTime?
  completedByUserId String?

  assignedToUserId String?
  assignedToRole   Role?
  priority         Int?
  kind             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceReviewSettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  intervalValue Int
  intervalUnit  MaintenanceIntervalUnit

  nextReviewAt DateTime?
  lastReviewAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetMeterReading {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  meterType  MaintenanceMeterType
  value      Int
  recordedAt DateTime             @default(now())
  source     String?

  createdAt DateTime @default(now())

  @@index([assetId, meterType, recordedAt])
}

/// Maintenance pool — a named group of users responsible for asset maintenance.
model MaintenancePool {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String?

  company Company                 @relation(fields: [companyId], references: [id])
  members MaintenancePoolMember[]
  assets  Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name], name: "MaintenancePool_company_name_key")
  @@index([companyId])
}

/// Junction table linking users to maintenance pools.
model MaintenancePoolMember {
  id     String @id @default(cuid())
  poolId String
  userId String

  pool MaintenancePool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([poolId, userId], name: "MaintenancePoolMember_pool_user_key")
  @@index([userId])
}

/// Registered device for NexBridge Connect / mobile app. Used for device
/// binding (max N devices per user) and license enforcement.
model UserDevice {
  id           String    @id @default(cuid())
  userId       String
  companyId    String
  deviceId     String /// Machine fingerprint hash
  platform     String /// "nexbridge-macos", "nexbridge-windows", "mobile-ios", etc.
  deviceName   String? /// Friendly name: "Paul's MacBook Pro"
  appVersion   String?
  lastSeenAt   DateTime  @default(now())
  registeredAt DateTime  @default(now())
  isRevoked    Boolean   @default(false)
  revokedAt    DateTime?

  // License state machine
  licenseType       DeviceLicenseType @default(CLOUD_SUBSCRIPTION)
  licenseExpiresAt  DateTime? /// Null for standalone lifetime
  graceEndsAt       DateTime? /// Set when subscription lapses (now + 14 days)
  exportCompletedAt DateTime? /// Tracks whether user exported their data

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, deviceId], name: "UserDevice_user_device_key")
  @@index([userId])
  @@index([companyId])
}

/// Grants visibility of a personal asset to a specific user.
model AssetShareGrant {
  id              String @id @default(cuid())
  assetId         String
  grantedToUserId String
  grantedByUserId String

  asset     Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  grantedTo User  @relation("AssetShareGrantReceiver", fields: [grantedToUserId], references: [id], onDelete: Cascade)
  grantedBy User  @relation("AssetShareGrantGiver", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([assetId, grantedToUserId], name: "AssetShareGrant_asset_user_key")
  @@index([grantedToUserId])
}

model InventoryPosition {
  id        String @id @default(cuid())
  companyId String

  itemType InventoryItemType
  itemId   String

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  quantity  Decimal @db.Decimal(18, 4)
  totalCost Decimal @db.Decimal(14, 2)

  metadata Json?

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, itemType, itemId, locationId], name: "InventoryPosition_company_item_location_key")
  @@index([companyId, locationId])
}

/// v1 material planning & procurement models

enum BomPricingSnapshotStatus {
  DRAFT
  LOCKED
  ARCHIVED
}

/// Snapshot of a BOM pricing scrape. One per "Get Local Pricing" action.
/// Results are persisted so subsequent visits don't re-scrape.
model BomPricingSnapshot {
  id                String @id @default(cuid())
  companyId         String
  projectId         String
  estimateVersionId String

  zipCode         String?
  totalLines      Int
  searchableLines Int

  status BomPricingSnapshotStatus @default(DRAFT)

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  project         Project         @relation(fields: [projectId], references: [id])
  estimateVersion EstimateVersion @relation(fields: [estimateVersionId], references: [id])
  createdBy       User?           @relation(fields: [createdByUserId], references: [id])

  hits BomPricingHit[]

  @@index([companyId, projectId])
  @@index([projectId, estimateVersionId])
}

/// Individual BOM line searched within a snapshot.
model BomPricingHit {
  id         String @id @default(cuid())
  snapshotId String

  sowItemId    String
  lineNo       Int
  description  String
  categoryCode String?
  searchQuery  String

  materialAmount Float?
  qty            Float?
  unit           String?

  /// Index of the selected product (0-based). Null = not yet selected.
  selectedProductIdx Int?

  snapshot BomPricingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sowItem  SowItem            @relation(fields: [sowItemId], references: [id])

  products BomPricingProduct[]

  @@index([snapshotId])
  @@index([sowItemId])
}

/// A supplier product result for a BOM pricing hit.
model BomPricingProduct {
  id    String @id @default(cuid())
  hitId String
  idx   Int /// Display order (0, 1, 2…)

  provider    String /// e.g. "homedepot", "lowes"
  productId   String /// Provider-specific product ID
  title       String
  brand       String?
  modelNumber String?

  price    Float?
  wasPrice Float?
  unit     String?

  imageUrl   String?
  productUrl String?
  rating     Float?
  inStock    Boolean?

  storeName    String?
  storeAddress String? /// street line
  storeCity    String?
  storeState   String? /// 2-letter
  storeZip     String?
  storePhone   String?

  /// Optional link to canonical product catalog.
  catalogItemId String?

  rawJson Json?

  createdAt DateTime @default(now())

  hit         BomPricingHit @relation(fields: [hitId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem?  @relation(fields: [catalogItemId], references: [id])

  @@index([hitId])
  @@index([catalogItemId], map: "BomPricingProduct_catalog_item_idx")
}

/// Long-lived price observation. Every scrape appends rows here.
/// Used for trending, seasonal analysis, and supplier comparison.
model MaterialPriceObservation {
  id        String @id @default(cuid())
  companyId String

  provider  String /// "homedepot", "lowes"
  productId String /// Provider-specific product ID
  title     String
  brand     String?

  searchQuery String /// Normalized query that found this product
  price       Float?
  zipCode     String?

  observedAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, searchQuery, observedAt])
  @@index([companyId, productId, observedAt])
  @@index([companyId, provider, observedAt])
}

// ── Procurement Intelligence: Canonical Catalog & Vendor Registry ──────────

enum VendorProviderType {
  SERPAPI
  BIGBOX
  WEB_SCRAPER
  MANUAL
  API
}

/// Canonical product identity. One row = one real-world product regardless of vendor.
/// specHash is computed from normalized product attributes.
model CatalogItem {
  id          String   @id @default(cuid())
  specHash    String   @unique
  category    String /// "KIT", "LBR", "DRY", "PLM", etc.
  productType String /// "Base Cabinet", "2x4", "Type X", etc.
  description String /// Human-readable canonical name
  unit        String /// "EA", "LF", "SF", etc.
  width       String? /// Normalized dimension
  height      String?
  depth       String?
  finish      String? /// "White Shaker", "#2 Pine", etc.
  specJson    Json? /// Full spec attributes for extensibility
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendorQuotes       VendorQuote[]
  priceListItems     PriceListItem[]
  bomPricingProducts BomPricingProduct[]

  @@index([category], map: "CatalogItem_category_idx")
  @@index([category, productType], map: "CatalogItem_category_type_idx")
}

/// DB-backed vendor configuration ("scraping address book").
/// Each row defines how to reach a vendor for pricing + availability.
model VendorRegistry {
  id           String             @id @default(cuid())
  code         String             @unique /// "RTA", "USKITCHEN", "HOMEDEPOT", "LOWES"
  name         String /// Display name
  websiteUrl   String? /// Base URL
  providerType VendorProviderType /// How we fetch data from this vendor
  isEnabled    Boolean            @default(true)

  /// For WEB_SCRAPER: URL patterns, CSS/regex selectors, sitemap URLs
  scrapeConfig Json?
  /// For API type: endpoint, auth method, headers
  apiConfig    Json?
  /// Rate limiting: { requestsPerMinute, delayMs, maxRetries }
  rateLimit    Json?
  /// How this vendor prefixes SKUs (e.g. "SW-")
  skuPrefix    String?
  /// Cross-prefix mapping JSON (e.g. { "S-ONB-": "BS-" })
  prefixMap    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes VendorQuote[]
}

/// Per-vendor pricing + availability for a canonical product.
model VendorQuote {
  id            String    @id @default(cuid())
  catalogItemId String
  vendorId      String
  vendorSku     String? /// Vendor-specific SKU (e.g. "SW-B24")
  unitPrice     Float?
  wasPrice      Float? /// Previous/list price if on sale
  currency      String    @default("USD")
  inStock       Boolean?
  stockQty      Int? /// Exact quantity if available
  leadTimeDays  Int? /// Estimated delivery days
  shippingCost  Float?
  productUrl    String? /// Direct link to product page
  imageUrl      String?
  scrapedAt     DateTime /// When this quote was captured
  expiresAt     DateTime? /// When this quote is considered stale
  rawJson       Json? /// Full scrape response for debugging
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  catalogItem CatalogItem    @relation(fields: [catalogItemId], references: [id])
  vendor      VendorRegistry @relation(fields: [vendorId], references: [id])

  @@unique([catalogItemId, vendorId, vendorSku], map: "VendorQuote_item_vendor_sku_key")
  @@index([catalogItemId, scrapedAt], map: "VendorQuote_item_scraped_idx")
  @@index([vendorId, scrapedAt], map: "VendorQuote_vendor_scraped_idx")
}

enum MaterialRequirementStatus {
  PLANNED
  DUE_SOON
  LATE
  ORDERED
  RECEIVED
  CANCELED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}


  country      String  @default("US")
  state        String
  county       String?
  city         String?
  postalCode   String?
  postalPrefix String?

  /// Effective tax burden as a fraction of gross wages.
  fedRate      Float
  ficaRate     Float
  medicareRate Float
  stateRate    Float
  localRate    Float

  /// Option B semantics: show taxes in dts_* and offset via in-lieu so
  /// net == 1099 total.
  representational Boolean @default(true)


  invitedByUserId String
  active          Boolean                @default(true)
  notes           String?                @db.Text

  project   Project @relation("CollaborationProject", fields: [projectId], references: [id])
  company   Company @relation("CollaborationCompany", fields: [companyId], references: [id])
  invitedBy User    @relation("CollaborationInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([projectId, companyId], name: "ProjectCollaboration_project_company_key")
  @@index([companyId, active], map: "ProjectCollaboration_company_active_idx")
  @@index([projectId, role], map: "ProjectCollaboration_project_role_idx")
}

model TaxJurisdiction {
  id String @id @default(cuid())


/// Cross-tenant project collaboration link.
/// Connects a collaborating Company (client, sub, consultant, etc.) to a
/// project owned by another Company. The project owner (Project.companyId)
/// is always the primary; the collaborating org is subordinate on that project.
/// Access for individual users within the collaborating org is resolved
/// dynamically: ProjectCollaboration.visibility caps what the org can see,
/// and the user's RoleProfile within their own Company further restricts.
model ProjectCollaboration {
  id              String                 @id @default(cuid())
  projectId       String
  companyId       String
  role            CollaborationRole
  visibility      ProjectVisibilityLevel @default(LIMITED)
  invitedAt       DateTime               @default(now())

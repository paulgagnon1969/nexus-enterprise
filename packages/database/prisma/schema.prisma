/// Per-user notification preferences, optionally scoped to a company/project.
/// Controls which push notifications the user receives and how.
model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String
  companyId String?
  projectId String?

  /// Notify on any new daily log in the user's projects
  dailyLogAlerts    Boolean                @default(true)
  /// Push immediately for INCIDENT-type daily logs
  incidentImmediate Boolean                @default(true)
  /// Morning/evening progress digest schedule
  progressDigest    ProgressDigestSchedule @default(NONE)
  /// Flexible JSON filter for advanced polling criteria
  /// e.g. { "logTypes": ["INCIDENT","JSA"], "projectIds": [...] }
  pollingCriteria   Json?

  /// Daily Brief: preferred delivery time (HH:mm, UTC)
  dailyBriefTime     String    @default("06:00")
  /// Daily Brief: content config override (lookbackDays, lookaheadDays)
  dailyBriefContent  Json?
  /// Last date the daily brief was sent (prevents double-send within a day)
  dailyBriefSentDate DateTime?

  /// Module toggles for push notifications
  petlChangeAlerts Boolean @default(true)
  taskAlerts       Boolean @default(true)
  scheduleAlerts   Boolean @default(true)
  /// Also send the Daily Brief via email
  emailDigest      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@unique([userId, companyId, projectId], map: "NotificationPreference_user_company_project_uk")
  @@index([userId], map: "NotificationPreference_user_idx")
}


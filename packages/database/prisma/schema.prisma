/// Simple test model used to validate migration pipelines.
/// Safe to keep or drop; not referenced by application code.
model DevMigrationTest {
  id        String   @id @default(cuid())
  note      String?
  createdAt DateTime @default(now())
}

/// Snapshot of a state-level occupational wage table (e.g. BLS OES export)
/// for a given state, year, and source. Used as the Golden "comp by state"
/// reference for market wages.
model StateOccupationalWageSnapshot {
  id        String   @id @default(cuid())
  stateCode String // e.g. "AZ", "NM"
  year      Int // e.g. 2024
  source    String   @default("BLS_OES")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wages StateOccupationalWage[]

  @@unique([stateCode, year, source], name: "StateOccWageSnapshot_state_year_source_key")
}

/// Single occupational wage record within a state snapshot (SOC code row).
model StateOccupationalWage {
  id                    String @id @default(cuid())
  snapshotId            String
  socCode               String // e.g. "47-2031"
  occupationName        String // e.g. "Carpenters"
  employment            Int?
  hourlyMean            Float?
  annualMean            Float?
  hourlyP10             Float?
  hourlyP25             Float?
  hourlyMedian          Float?
  hourlyP75             Float?
  hourlyP90             Float?
  annualP10             Float?
  annualP25             Float?
  annualMedian          Float?
  annualP75             Float?
  annualP90             Float?
  employmentPerThousand Float?
  locationQuotient      Float?

  snapshot StateOccupationalWageSnapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId, socCode], map: "StateOccWage_snapshot_soc_idx")
}

/// Mapping from Nexus/CP classifications (cpRole, workerClassCode) to SOC
/// occupation codes, so we can compare internal & CP comp against state
/// occupational wage tables.
model CompensationClassificationMapping {
  id              String   @id @default(cuid())
  cpRole          String?
  workerClassCode String?
  socCode         String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cpRole, workerClassCode, socCode], name: "CompClass_unique_triplet")
  @@index([cpRole], map: "CompClass_cpRole_idx")
  @@index([workerClassCode], map: "CompClass_workerClass_idx")
  @@index([socCode], map: "CompClass_socCode_idx")
}

model NexNetCandidate {
  id                       String                   @id @default(cuid())
  userId                   String?                  @unique
  companyId                String? // owning company/tenant for this candidate profile
  firstName                String?
  lastName                 String?
  email                    String?
  phone                    String?
  source                   NexNetSource             @default(REFERRAL)
  status                   NexNetStatus             @default(NOT_STARTED)
  visibilityScope          CandidateVisibilityScope @default(TENANT_ONLY)
  isHiddenFromDefaultViews Boolean                  @default(false)
  isDeletedSoft            Boolean                  @default(false)
  deletedAt                DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  user               User?      @relation(fields: [userId], references: [id])
  // companyId is a soft foreign key to Company.id; relation omitted for now.
  referralsAsReferee Referral[] @relation("RefereeCandidate")
}

model Referral {
  id                         String         @id @default(cuid())
  referrerUserId             String
  prospectName               String?
  prospectEmail              String?
  prospectPhone              String?
  token                      String         @unique
  candidateId                String?
  refereeUserId              String?
  referralConfirmedByReferee Boolean        @default(false)
  referralConfirmedAt        DateTime?
  referralRejectedByReferee  Boolean        @default(false)
  status                     ReferralStatus @default(INVITED)
  referralStartDate          DateTime?
  referralEndDate            DateTime?
  incentiveRate              Float?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  // Optional linkage back to a personal contact when the referral was
  // initiated from the user's confidential address book.
  personalContactId String?

  referrer        User             @relation("ReferralsSent", fields: [referrerUserId], references: [id])
  referee         User?            @relation("ReferralsReceived", fields: [refereeUserId], references: [id])
  candidate       NexNetCandidate? @relation("RefereeCandidate", fields: [candidateId], references: [id])
  personalContact PersonalContact? @relation(fields: [personalContactId], references: [id])
}

enum NexNetSource {
  REFERRAL
  PUBLIC_APPLY
  MIGRATED
  IMPORTED
}

enum NexNetStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  HIRED
  REJECTED
  TEST
}

enum ReferralStatus {
  INVITED
  CONFIRMED
  REJECTED
  APPLIED
  HIRED
  EXPIRED
}

enum ReferralRelationshipType {
  PERSONAL
  COMPANY
}

model ReferralRelationship {
  id              String                   @id @default(cuid())
  referrerUserId  String
  refereeUserId   String
  companyId       String?
  type            ReferralRelationshipType
  referralId      String?
  companyInviteId String?
  createdAt       DateTime                 @default(now())

  referrer User     @relation("ReferralRelationshipReferrer", fields: [referrerUserId], references: [id])
  referee  User     @relation("ReferralRelationshipReferee", fields: [refereeUserId], references: [id])
  company  Company? @relation(fields: [companyId], references: [id])

  @@index([referrerUserId], map: "ReferralRel_referrer_idx")
  @@index([refereeUserId], map: "ReferralRel_referee_idx")
  @@index([companyId], map: "ReferralRel_company_idx")
}

/// Visibility scope for candidates in the Nex-Net / Prospective Candidates pool.
enum CandidateVisibilityScope {
  TENANT_ONLY
  GLOBAL_POOL
  PRIVATE_TEST
}

/// Source system for a personal contact record.
enum PersonalContactSource {
  UPLOAD
  WINDOWS
  MACOS
  IOS
  ANDROID
}

/// Domain entity a personal contact is linked to (e.g. candidate/worker card).
enum PersonalContactSubjectType {
  CANDIDATE
  WORKER
}

/// Global, confidential contact belonging to a single user profile (not tenant-scoped).
model PersonalContact {
  id          String                @id @default(cuid())
  ownerUserId String
  displayName String?
  firstName   String?
  lastName    String?
  email       String? // Primary email (used for invites)
  phone       String? // Primary phone (used for invites)
  allEmails   Json? // Array of all email addresses from device
  allPhones   Json? // Array of all phone numbers from device
  source      PersonalContactSource @default(UPLOAD)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  owner     User                  @relation(fields: [ownerUserId], references: [id])
  links     PersonalContactLink[]
  referrals Referral[]

  @@index([ownerUserId, email], map: "PersonalContact_owner_email_idx")
  @@index([ownerUserId, phone], map: "PersonalContact_owner_phone_idx")
}

/// Link from a personal contact to a candidate/worker in the domain model so
/// the owner can see "you know this person" on those cards.
model PersonalContactLink {
  id                String                     @id @default(cuid())
  personalContactId String
  subjectType       PersonalContactSubjectType
  subjectId         String
  tenantId          String?
  note              String?
  createdAt         DateTime                   @default(now())

  personalContact PersonalContact @relation(fields: [personalContactId], references: [id])

  @@index([personalContactId], map: "PersonalContactLink_contact_idx")
  @@index([subjectType, subjectId], map: "PersonalContactLink_subject_idx")
}

/// Status of a candidate training assignment.
enum CandidateTrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

/// Outcome of an individual training attempt.
enum CandidateTrainingAttemptStatus {
  PASSED
  FAILED
  ABANDONED
}

/// Status of a candidate certification / license.
enum CandidateCertificationStatus {
  PENDING_VERIFICATION
  VALID
  EXPIRED
  REVOKED
}

/// Status of cross-tenant interest in a candidate.
enum CandidateInterestStatus {
  REQUESTED
  APPROVED
  DECLINED
  HIRED
}

/// Catalog of training modules that can be assigned to Nex-Net candidates.
model TrainingModule {
  id                String   @id @default(cuid())
  companyId         String? // owning company/tenant, null = global module
  code              String
  title             String
  description       String?
  type              String // e.g. "ONLINE_COURSE", "DOCUMENT", "IN_PERSON"
  durationMinutes   Int?
  isActive          Boolean  @default(true)
  isRequiredDefault Boolean  @default(false)
  externalLmsId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Note: companyId is a soft foreign key to Company.id; we intentionally
  // omit a Prisma @relation here to keep the schema simple while iterating.

  @@unique([companyId, code], name: "TrainingModule_company_code_key")
}

/// Catalog of certification / license types that candidates can hold.
model CertificationType {
  id                    String   @id @default(cuid())
  companyId             String? // owning company/tenant, null = global (e.g. state RN license)
  code                  String
  name                  String
  description           String?
  issuingAuthority      String?
  defaultValidityMonths Int?
  isActive              Boolean  @default(true)
  isRequiredDefault     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  /// Optional HTML template used when rendering certificates of this type.
  /// Managed by Nexus System Admins via the certifications UI.
  certificateTemplateHtml String?

  // Note: companyId is a soft foreign key to Company.id; no Prisma @relation
  // is declared here to avoid additional back-relations while iterating.

  @@unique([companyId, code], name: "CertificationType_company_code_key")
}

/// Assignment of a training module to a specific Nex-Net candidate.
model CandidateTrainingAssignment {
  id               String   @id @default(cuid())
  candidateId      String
  trainingModuleId String
  assignedByUserId String?
  assignedAt       DateTime @default(now())

  status      CandidateTrainingStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime?
  score       Float?
  attempts    Int                     @default(0)
  isRequired  Boolean                 @default(true)
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  // Scalar foreign keys only; relations are enforced at the application layer.

  @@index([candidateId], map: "CandidateTrainingAssignment_candidate_idx")
  @@index([trainingModuleId], map: "CandidateTrainingAssignment_training_idx")
}

/// Individual attempt record for a candidate's training assignment.
model CandidateTrainingAttempt {
  id           String                         @id @default(cuid())
  assignmentId String
  startedAt    DateTime                       @default(now())
  finishedAt   DateTime?
  status       CandidateTrainingAttemptStatus
  score        Float?
  metadata     Json?
  createdAt    DateTime                       @default(now())

  // assignmentId is a soft foreign key to CandidateTrainingAssignment.id

  @@index([assignmentId], map: "CandidateTrainingAttempt_assignment_idx")
}

/// Instance of a certification / license held by a Nex-Net candidate.
model CandidateCertification {
  id                  String                       @id @default(cuid())
  candidateId         String
  certificationTypeId String
  licenseNumber       String?
  issuedBy            String?
  issuedAt            DateTime?
  effectiveAt         DateTime?
  expiresAt           DateTime?
  status              CandidateCertificationStatus @default(PENDING_VERIFICATION)
  verifiedByUserId    String?
  verifiedAt          DateTime?
  verificationNotes   String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  // candidateId and certificationTypeId are soft foreign keys.

  @@index([candidateId], map: "CandidateCertification_candidate_idx")
  @@index([certificationTypeId], map: "CandidateCertification_type_idx")
}

/// Supporting documents for a candidate certification (e.g. PDF license).
model CandidateCertificationDocument {
  id                       String   @id @default(cuid())
  candidateCertificationId String
  storageUrl               String
  fileName                 String
  mimeType                 String
  sizeBytes                Int?
  uploadedByUserId         String?
  uploadedAt               DateTime @default(now())
  description              String?

  // candidateCertificationId is a soft foreign key to CandidateCertification.id

  @@index([candidateCertificationId], map: "CandidateCertDocument_cert_idx")
}

/// Anonymized, marketplace-facing profile for a Nex-Net candidate.
model CandidateMarketProfile {
  candidateId        String   @id
  publicId           String   @unique
  headline           String?
  skillsSummary      String?
  credentialsSummary String?
  locationRegion     String?
  ratingNumeric      Float?
  ratingLabel        String?
  rateMin            Float?
  rateMax            Float?
  updatedAt          DateTime @default(now()) @updatedAt
}

/// Controls which companies/tenants can see a given candidate in the pool.
model CandidatePoolVisibility {
  id                 String   @id @default(cuid())
  candidateId        String
  visibleToCompanyId String? // null = visible to all subscribers in marketplace
  isAllowed          Boolean  @default(true)
  createdAt          DateTime @default(now())
  createdByUserId    String

  // Scalar foreign keys only; relations to NexNetCandidate, User, Company
  // are enforced at the application layer.

  @@index([candidateId], map: "CandidatePoolVisibility_candidate_idx")
  @@index([visibleToCompanyId], map: "CandidatePoolVisibility_visible_company_idx")
}

/// Interest expressed by another company/tenant in a candidate.
model CandidateInterest {
  id                  String                  @id @default(cuid())
  candidateId         String
  requestingCompanyId String
  status              CandidateInterestStatus @default(REQUESTED)
  notes               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  handledByUserId     String?

  /// Optional employment window for this (candidate, company) interest when it
  /// represents an actual assignment or hire.
  employmentStartDate DateTime?
  employmentEndDate   DateTime?

  /// Snapshot of pay information at the time this interest transitioned to a
  /// HIRED/active assignment. These are best-effort fields populated from HR
  /// portfolio and/or Worker compensation and are not intended to be a full
  /// payroll ledger.
  baseHourlyRate     Float?
  dayRate            Float?
  cpHourlyRate       Float?
  cpFringeHourlyRate Float?

  // Scalar foreign keys only; relations to NexNetCandidate, Company, User
  // are enforced at the application layer.

  @@index([candidateId], map: "CandidateInterest_candidate_idx")
  @@index([requestingCompanyId], map: "CandidateInterest_requesting_company_idx")
}

// =============================================================================
// PnP (Policy & Procedure) Library
// =============================================================================

/// Category for PnP documents
enum PnpCategory {
  SAFETY
  HR
  OPERATIONS
  COMPLIANCE
  QUALITY
  INSURANCE
  GENERAL
}

/// Review status for tenant PnP documents
enum PnpReviewStatus {
  PENDING_REVIEW // Seeded, not yet reviewed by tenant admin
  APPROVED // Tenant admin approved as-is
  MODIFIED_APPROVED // Tenant modified and approved their version
  REJECTED // Tenant rejected (won't use this policy)
}

/// System-level PnP library document (NEXUS-owned master copy)
model PnpDocument {
  id               String      @id @default(cuid())
  code             String      @unique // e.g. "SAFETY-001", "HR-ONBOARD-001"
  title            String
  category         PnpCategory
  description      String?
  active           Boolean     @default(true)
  sortOrder        Int         @default(0)
  currentVersionId String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  currentVersion PnpDocumentVersion?  @relation("PnpDocCurrentVersion", fields: [currentVersionId], references: [id])
  versions       PnpDocumentVersion[]
  tenantCopies   TenantPnpDocument[]
}

/// Version of a system-level PnP document
model PnpDocumentVersion {
  id              String    @id @default(cuid())
  documentId      String
  versionNo       Int
  versionLabel    String? // e.g. "2024-Q1 Update"
  releaseNotes    String?
  htmlContent     String
  contentHash     String?
  effectiveDate   DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  document     PnpDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  currentFor   PnpDocument?        @relation("PnpDocCurrentVersion")
  tenantCopies TenantPnpDocument[] @relation("TenantPnpSourceVersion")

  @@unique([documentId, versionNo], name: "PnpDocVersion_doc_version_key")
  @@index([documentId], map: "PnpDocVersion_doc_idx")
}

/// Tenant-level PnP document (seeded from system library or custom-created)
model TenantPnpDocument {
  id               String      @id @default(cuid())
  companyId        String
  code             String
  title            String
  category         PnpCategory
  description      String?
  active           Boolean     @default(true)
  currentVersionId String?     @unique

  // Source tracking (null if tenant-created from scratch)
  sourcePnpDocumentId String?
  sourceVersionId     String?

  // Fork status – becomes true when tenant modifies seeded content
  isFork         Boolean   @default(false)
  forkedAt       DateTime?
  forkedByUserId String?

  // Approval workflow
  reviewStatus     PnpReviewStatus @default(PENDING_REVIEW)
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourcePnpDocument PnpDocument?               @relation(fields: [sourcePnpDocumentId], references: [id], onDelete: SetNull)
  sourceVersion     PnpDocumentVersion?        @relation("TenantPnpSourceVersion", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  currentVersion    TenantPnpDocumentVersion?  @relation("TenantPnpDocCurrentVersion", fields: [currentVersionId], references: [id])
  versions          TenantPnpDocumentVersion[]

  @@unique([companyId, code], name: "TenantPnpDocument_company_code_key")
  @@index([companyId, category], map: "TenantPnpDocument_company_category_idx")
  @@index([companyId, reviewStatus], map: "TenantPnpDocument_company_status_idx")
  @@index([sourcePnpDocumentId], map: "TenantPnpDocument_source_idx")
}

/// Version of a tenant-level PnP document
model TenantPnpDocumentVersion {
  id           String  @id @default(cuid())
  documentId   String
  versionNo    Int
  versionLabel String?
  notes        String?
  htmlContent  String
  contentHash  String?

  // Disclaimer is auto-generated based on reviewStatus when rendering
  disclaimerHtml String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  document   TenantPnpDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  currentFor TenantPnpDocument? @relation("TenantPnpDocCurrentVersion")

  @@unique([documentId, versionNo], name: "TenantPnpDocVersion_doc_version_key")
  @@index([documentId], map: "TenantPnpDocVersion_doc_idx")
}

// =============================================================================
// Document Import System (Staging & Archive)
// =============================================================================

/// Status of a document scan job
enum DocumentScanJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// Status of a staged document
enum StagedDocumentStatus {
  ACTIVE // Unpublished eDocs - available for editing/tagging
  ARCHIVED // Soft-deleted, not visible to regular users
  PUBLISHED // Published and available organization-wide
}

/// Status of HTML conversion for a staged document
enum HtmlConversionStatus {
  PENDING
  CONVERTING
  COMPLETED
  FAILED
  SKIPPED // For unsupported file types
}

/// AI-guessed document type based on filename and content analysis
enum DocumentTypeGuess {
  LIKELY_PROCEDURE // Steps, numbered lists, SOP indicators
  LIKELY_POLICY // Policy/compliance language
  LIKELY_FORM // Forms, templates, checklists
  REFERENCE_DOC // General reference material
  UNLIKELY_PROCEDURE // Plain paragraphs, no structure
  UNKNOWN // Unable to classify
}

/// Job record for scanning external file systems for documents
model DocumentScanJob {
  id                 String                @id @default(cuid())
  companyId          String
  scanPath           String // Root path being scanned
  status             DocumentScanJobStatus @default(PENDING)
  documentsFound     Int                   @default(0)
  documentsProcessed Int                   @default(0)
  errorMessage       String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdByUserId    String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       User             @relation(fields: [createdByUserId], references: [id])
  stagedDocuments StagedDocument[]

  @@index([companyId, status], map: "DocumentScanJob_company_status_idx")
  @@index([createdByUserId], map: "DocumentScanJob_user_idx")
}

/// Staged document discovered during a scan, awaiting import decision
model StagedDocument {
  id                 String               @id @default(cuid())
  companyId          String
  scanJobId          String
  fileName           String
  filePath           String // Full path to the file
  breadcrumb         String[] // Path segments for display
  fileType           String // Extension (pdf, docx, etc.)
  fileSize           BigInt // Size in bytes
  mimeType           String?
  thumbnailUrl       String?
  status             StagedDocumentStatus @default(ACTIVE)
  scannedAt          DateTime             @default(now())
  scannedByUserId    String
  archivedAt         DateTime?
  archivedByUserId   String?
  importedAt         DateTime?
  importedByUserId   String?
  importedToType     String? // e.g. "safety", "bkm"
  importedToCategory String? // e.g. "ppe", "general-safety", "hazard-communication"
  displayTitle       String? // Override title for display (vs fileName)
  displayDescription String? // Description shown in document listings
  oshaReference      String? // OSHA CFR reference if applicable
  sortOrder          Int? // Custom sort order within category
  metadata           Json? // Additional file metadata

  // Tagging for filtering and categorization
  tags        String[] // User-defined tags for filtering
  category    String? // Primary category (e.g., "Safety", "HR", "Operations")
  subcategory String? // Subcategory for finer organization

  // Revision control
  revisionNumber  Int       @default(1) // Current revision number
  revisionDate    DateTime? // Date of current revision
  revisionNotes   String? // Notes about what changed in this revision
  revisionHistory Json? // JSON array of previous revision info

  // Document classification (AI-guessed)
  documentTypeGuess    DocumentTypeGuess? // Auto-classified document type
  classificationScore  Float? // Confidence score (0-1)
  classificationReason String? // Why it was classified this way

  // Publishing workflow
  publishedAt       DateTime? // When document was published
  publishedByUserId String? // Who published it

  // Text extraction (for search and classification)
  textContent  String? @db.Text // Extracted plain text for search/classification
  originalPath String? // Original path where file lives (source of truth)

  // HTML conversion fields
  htmlContent      String?               @db.Text // Converted HTML content
  conversionStatus HtmlConversionStatus? // Status of HTML conversion
  conversionError  String? // Error message if conversion failed
  convertedAt      DateTime? // When conversion completed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scanJob     DocumentScanJob @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  scannedBy   User            @relation("StagedDocumentScannedBy", fields: [scannedByUserId], references: [id])
  archivedBy  User?           @relation("StagedDocumentArchivedBy", fields: [archivedByUserId], references: [id])
  importedBy  User?           @relation("StagedDocumentImportedBy", fields: [importedByUserId], references: [id])
  publishedBy User?           @relation("StagedDocumentPublishedBy", fields: [publishedByUserId], references: [id])

  @@index([companyId, status], map: "StagedDocument_company_status_idx")
  @@index([scanJobId], map: "StagedDocument_job_idx")
  @@index([companyId, fileType], map: "StagedDocument_company_type_idx")
  @@index([companyId, importedToType, importedToCategory], map: "StagedDocument_imported_idx")
  @@index([companyId, category], map: "StagedDocument_company_category_idx")
}

// =============================================================================
// Claim Journal System (Carrier Negotiation Tracking)
// =============================================================================

/// Entry type for claim journal entries
enum ClaimJournalEntryType {
  SUBMISSION // Submitted claim/supplement to carrier
  RESPONSE // Received response from carrier
  CALL // Phone call with carrier
  EMAIL // Email correspondence
  MEETING // In-person or video meeting
  NOTE // Internal note (not shared with carrier)
  APPROVAL // Carrier approved item(s)
  DENIAL // Carrier denied item(s)
  PARTIAL_APPROVAL // Carrier partially approved
}

/// Direction of communication for journal entries
enum ClaimJournalDirection {
  INBOUND // From carrier to us
  OUTBOUND // From us to carrier
  INTERNAL // Internal note, not external communication
}

/// Carrier contacts - company-wide registry of adjusters, supervisors, etc.
model CarrierContact {
  id        String @id @default(cuid())
  companyId String

  carrierName String // "State Farm", "Allstate", "Citizens"
  contactName String // "John Smith"
  role        String? // "Field Adjuster", "Desk Adjuster", "Supervisor"
  email       String?
  phone       String?
  notes       String? @db.Text

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntries ClaimJournalEntry[]

  @@index([companyId], map: "CarrierContact_company_idx")
  @@index([companyId, carrierName], map: "CarrierContact_company_carrier_idx")
  @@index([companyId, isActive], map: "CarrierContact_company_active_idx")
}

/// Claim journal entries - append-only audit trail for carrier negotiations
model ClaimJournalEntry {
  id        String @id @default(cuid())
  projectId String

  // Entry classification
  entryType ClaimJournalEntryType
  direction ClaimJournalDirection

  // Who was involved (linked contact OR freeform for one-offs)
  carrierContactId  String?
  actorNameOverride String? // Freeform name if contact not in system
  actorOrgOverride  String? // Freeform carrier name if not using contact

  // When the event actually happened (vs createdAt which is when logged)
  occurredAt DateTime

  // Content (immutable after creation - corrections via new entry)
  summary String // One-line headline
  details String? @db.Text // Full notes, supports markdown

  // Amounts involved (optional)
  amountDisputed Decimal? @db.Decimal(12, 2)
  amountApproved Decimal? @db.Decimal(12, 2)
  amountDenied   Decimal? @db.Decimal(12, 2)

  // Tags for filtering (stored as array)
  tags String[] // e.g., ["supplement-1", "roofing", "depreciation"]

  // Audit trail
  createdAt   DateTime @default(now())
  createdById String

  // Corrections: if entry needs fixing, create new entry that references original
  // Original entry stays visible with "corrected" indicator
  correctsEntryId String? @unique

  // Relations
  project        Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  carrierContact CarrierContact?          @relation(fields: [carrierContactId], references: [id])
  createdBy      User                     @relation("ClaimJournalEntryCreatedBy", fields: [createdById], references: [id])
  correctsEntry  ClaimJournalEntry?       @relation("ClaimJournalCorrections", fields: [correctsEntryId], references: [id])
  correctedBy    ClaimJournalEntry?       @relation("ClaimJournalCorrections")
  attachments    ClaimJournalAttachment[]

  @@index([projectId], map: "ClaimJournalEntry_project_idx")
  @@index([projectId, occurredAt], map: "ClaimJournalEntry_project_occurred_idx")
  @@index([projectId, entryType], map: "ClaimJournalEntry_project_type_idx")
  @@index([carrierContactId], map: "ClaimJournalEntry_contact_idx")
  @@index([createdById], map: "ClaimJournalEntry_creator_idx")
}

/// Attachments for claim journal entries (proof, documentation)
model ClaimJournalAttachment {
  id             String @id @default(cuid())
  journalEntryId String

  fileName   String
  fileType   String? // MIME type
  fileSize   Int? // Size in bytes
  storageKey String // S3/storage key
  storageUrl String? // Public/signed URL if applicable

  uploadedAt   DateTime @default(now())
  uploadedById String

  journalEntry ClaimJournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation("ClaimJournalAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([journalEntryId], map: "ClaimJournalAttachment_entry_idx")
  @@index([uploadedById], map: "ClaimJournalAttachment_uploader_idx")
}

// =============================================================================
// Voice Journal Notes (VJN) — Personal Voice Notes with AI Transcription
// =============================================================================

enum VoiceJournalNoteStatus {
  DRAFT // Private — only the author can see
  SHARED // At least one share exists
  ARCHIVED // Author archived it
}

/// Personal voice note with AI transcription. Tagged to a source module/entity
/// but private until explicitly shared.
model VoiceJournalNote {
  id          String  @id @default(cuid())
  companyId   String
  projectId   String?
  createdById String

  // Audio (primary artifact — always present)
  voiceRecordingUrl String // GCS URL
  voiceDurationSecs Int // duration for display

  // Language support
  language         String  @default("en") // ISO 639-1: "en", "es", etc.
  deviceTranscript String? @db.Text // Raw on-device speech recognition output

  // AI-derived text
  aiTranscriptRaw  String? @db.Text // Whisper verbatim (source language)
  aiText           String? @db.Text // GPT-cleaned text (source language)
  aiSummary        String? @db.Text // GPT-cleaned summary (source language)
  aiTextTranslated String? @db.Text // English translation (populated when language != "en")
  aiDetails        String? @db.Text // GPT-structured details (for journal context)
  aiGenerated      Boolean @default(true)

  // Source context: where was this VJN recorded?
  sourceModule   String? // 'daily_log' | 'journal' | 'messaging' | null (standalone)
  sourceEntityId String? // ID of the daily log, journal entry, thread, etc.
  sourceLabel    String? // human-readable: "Daily Log #47 — Johnson Roof"

  // Publishing
  status    VoiceJournalNoteStatus @default(DRAFT)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  company   Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project?                @relation(fields: [projectId], references: [id])
  createdBy User                    @relation("VoiceJournalNoteCreatedBy", fields: [createdById], references: [id])
  shares    VoiceJournalNoteShare[]

  @@index([createdById, status, createdAt], map: "VoiceJournalNote_creator_status_idx")
  @@index([companyId, projectId, createdAt], map: "VoiceJournalNote_company_project_idx")
  @@index([sourceModule, sourceEntityId], map: "VoiceJournalNote_source_idx")
}

/// Tracks where a VJN was shared to (a single VJN can be shared to multiple targets)
model VoiceJournalNoteShare {
  id    String @id @default(cuid())
  vjnId String

  // Where was it shared TO?
  targetModule   String // 'daily_log' | 'journal' | 'messaging'
  targetEntityId String? // ID of the target entity

  // What was shared? (author may have edited the AI text before sharing)
  sharedSummary String? @db.Text
  sharedDetails String? @db.Text

  sharedAt   DateTime @default(now())
  sharedById String

  vjn      VoiceJournalNote @relation(fields: [vjnId], references: [id], onDelete: Cascade)
  sharedBy User             @relation("VoiceJournalNoteShareSharedBy", fields: [sharedById], references: [id])

  @@index([vjnId], map: "VoiceJournalNoteShare_vjn_idx")
  @@index([targetModule, targetEntityId], map: "VoiceJournalNoteShare_target_idx")
}

// =============================================================================
// Field-Level Security System
// =============================================================================

/// Company-scoped field-level security policies.
/// Each policy defines access rules for a specific "resourceKey" (e.g. "petl.rcvAmount").
model FieldSecurityPolicy {
  id          String   @id @default(cuid())
  companyId   String
  resourceKey String // e.g. "petl.rcvAmount", "project.financial.payments"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions FieldSecurityPermission[]

  @@unique([companyId, resourceKey], name: "FieldSecurityPolicy_company_resource_key")
  @@index([companyId], map: "FieldSecurityPolicy_company_idx")
}

/// Role-based permissions for a field security policy.
/// Tracks canView, canEdit, canExport per role code.
model FieldSecurityPermission {
  id        String  @id @default(cuid())
  policyId  String
  roleCode  String // "CLIENT", "CREW", "FOREMAN", "SUPER", "PM", "ADMIN", "OWNER", "SUPER_ADMIN"
  canView   Boolean @default(true)
  canEdit   Boolean @default(false)
  canExport Boolean @default(true)

  policy FieldSecurityPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, roleCode], name: "FieldSecurityPermission_policy_role_key")
  @@index([policyId], map: "FieldSecurityPermission_policy_idx")
}

/// Audit log for field security policy changes.
model FieldSecurityAuditLog {
  id           String   @id @default(cuid())
  companyId    String
  policyId     String?
  resourceKey  String
  action       String // "CREATE", "UPDATE", "DELETE"
  actorUserId  String
  actorEmail   String
  previousJson Json?
  newJson      Json?
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt], map: "FieldSecurityAuditLog_company_created_idx")
  @@index([policyId], map: "FieldSecurityAuditLog_policy_idx")
}

// =============================================================================
// NEXUS System Documents (Publication & Distribution)
// =============================================================================

/// Publication target type for system documents
enum SystemDocumentPublicationTarget {
  ALL_TENANTS // Published to all tenant organizations
  SINGLE_TENANT // Published to a specific tenant only
}

/// Status of tenant document/manual copies (two-stage publishing)
enum TenantDocumentStatus {
  UNRELEASED // Received from NEXUS but not yet published to org
  PUBLISHED // Published and visible to org users
  ARCHIVED // Hidden/archived by tenant admin
}

/// Master document owned by NEXUS System (not tenant-scoped)
model SystemDocument {
  id               String   @id @default(cuid())
  code             String   @unique // Unique identifier code (e.g., "SOP-001")
  title            String
  description      String?
  category         String? // Primary category (e.g., "Safety", "HR", "Operations")
  subcategory      String? // Subcategory for finer organization
  tags             String[] // Tags for filtering
  active           Boolean  @default(true) // Soft delete
  currentVersionId String?  @unique
  publicSlug       String?  @unique // For branded public URLs (e.g., "ppe-policy")
  isPublic         Boolean  @default(false) // Whether accessible without auth
  createdByUserId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  currentVersion   SystemDocumentVersion?      @relation("SystemDocCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         SystemDocumentVersion[]
  publications     SystemDocumentPublication[]
  tenantCopies     TenantDocumentCopy[]
  manualDocuments  ManualDocument[] // Documents included in manuals
  shareLinks       DocumentShareLink[] // Private share links
  createdBy        User                        @relation("SystemDocumentCreatedBy", fields: [createdByUserId], references: [id])
  moduleCatalogCam ModuleCatalog?              @relation("ModuleCamDocument")

  @@index([category], map: "SystemDocument_category_idx")
  @@index([active], map: "SystemDocument_active_idx")
  @@index([isPublic], map: "SystemDocument_public_idx")
}

/// Immutable revision snapshot of a system document
model SystemDocumentVersion {
  id               String   @id @default(cuid())
  systemDocumentId String
  versionNo        Int // Sequential version number (1, 2, 3...)
  htmlContent      String   @db.Text // Rich text content
  contentHash      String? // Hash for change detection
  notes            String? // Revision notes (what changed)
  createdByUserId  String
  createdAt        DateTime @default(now())

  systemDocument     SystemDocument              @relation(fields: [systemDocumentId], references: [id], onDelete: Cascade)
  currentForDocument SystemDocument?             @relation("SystemDocCurrentVersion")
  publications       SystemDocumentPublication[]
  createdBy          User                        @relation("SystemDocVersionCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([systemDocumentId, versionNo], map: "SystemDocVersion_doc_version_key")
  @@index([systemDocumentId], map: "SystemDocVersion_doc_idx")
}

/// Publication record for distributing system documents to tenants
model SystemDocumentPublication {
  id                      String                          @id @default(cuid())
  systemDocumentId        String
  systemDocumentVersionId String
  targetType              SystemDocumentPublicationTarget
  targetCompanyId         String? // Null for ALL_TENANTS
  publishedAt             DateTime                        @default(now())
  publishedByUserId       String
  retractedAt             DateTime? // When unpublished (null = active)
  retractedByUserId       String?

  systemDocument        SystemDocument        @relation(fields: [systemDocumentId], references: [id], onDelete: Cascade)
  systemDocumentVersion SystemDocumentVersion @relation(fields: [systemDocumentVersionId], references: [id], onDelete: Cascade)
  targetCompany         Company?              @relation(fields: [targetCompanyId], references: [id], onDelete: Cascade)
  publishedBy           User                  @relation("SystemDocPubPublishedBy", fields: [publishedByUserId], references: [id])
  retractedBy           User?                 @relation("SystemDocPubRetractedBy", fields: [retractedByUserId], references: [id])

  @@index([systemDocumentId], map: "SystemDocPub_doc_idx")
  @@index([targetCompanyId], map: "SystemDocPub_company_idx")
  @@index([targetType, retractedAt], map: "SystemDocPub_target_active_idx")
}

/// Tenant's editable copy of a system document
model TenantDocumentCopy {
  id                     String               @id @default(cuid())
  companyId              String
  sourceSystemDocumentId String // Reference back to source for audit
  sourceVersionNo        Int // Version number when copied
  title                  String // Can be modified by tenant
  currentVersionId       String?              @unique
  status                 TenantDocumentStatus @default(UNRELEASED) // Two-stage publishing
  copiedByUserId         String
  copiedAt               DateTime             @default(now())
  publishedAt            DateTime? // When tenant admin published to org
  publishedByUserId      String? // User who published to org
  internalNotes          String?              @db.Text // Tenant-specific notes
  hasNewerSystemVersion  Boolean              @default(false) // Flag for update indicator
  updatedAt              DateTime             @updatedAt

  company              Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceSystemDocument SystemDocument              @relation(fields: [sourceSystemDocumentId], references: [id])
  currentVersion       TenantDocumentCopyVersion?  @relation("TenantDocCopyCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions             TenantDocumentCopyVersion[]
  copiedBy             User                        @relation("TenantDocCopyCopiedBy", fields: [copiedByUserId], references: [id])
  publishedBy          User?                       @relation("TenantDocCopyPublishedBy", fields: [publishedByUserId], references: [id])

  @@index([companyId], map: "TenantDocCopy_company_idx")
  @@index([sourceSystemDocumentId], map: "TenantDocCopy_source_idx")
  @@index([companyId, hasNewerSystemVersion], map: "TenantDocCopy_updates_idx")
  @@index([companyId, status], map: "TenantDocCopy_status_idx")
}

/// Version history for tenant's document copy
model TenantDocumentCopyVersion {
  id                   String   @id @default(cuid())
  tenantDocumentCopyId String
  versionNo            Int // Sequential version number
  htmlContent          String   @db.Text
  contentHash          String?
  notes                String? // What changed in this revision
  createdByUserId      String
  createdAt            DateTime @default(now())

  tenantDocumentCopy TenantDocumentCopy  @relation(fields: [tenantDocumentCopyId], references: [id], onDelete: Cascade)
  currentForCopy     TenantDocumentCopy? @relation("TenantDocCopyCurrentVersion")
  createdBy          User                @relation("TenantDocCopyVersionCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([tenantDocumentCopyId, versionNo], map: "TenantDocCopyVersion_copy_version_key")
  @@index([tenantDocumentCopyId], map: "TenantDocCopyVersion_copy_idx")
}

/// Tenant's copy of a manual when distributed from NEXUS
model TenantManualCopy {
  id                    String               @id @default(cuid())
  companyId             String
  sourceManualId        String // Reference to source manual
  sourceManualVersion   Int // Version when distributed
  title                 String // Can be customized by tenant
  status                TenantDocumentStatus @default(UNRELEASED)
  hasNewerSourceVersion Boolean              @default(false) // Flag for update indicator
  receivedAt            DateTime             @default(now())
  receivedByUserId      String // System user or admin who triggered distribution
  publishedAt           DateTime? // When tenant admin published to org
  publishedByUserId     String? // User who published
  internalNotes         String?              @db.Text
  updatedAt             DateTime             @updatedAt

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceManual Manual  @relation(fields: [sourceManualId], references: [id])
  receivedBy   User    @relation("TenantManualCopyReceivedBy", fields: [receivedByUserId], references: [id])
  publishedBy  User?   @relation("TenantManualCopyPublishedBy", fields: [publishedByUserId], references: [id])

  @@unique([companyId, sourceManualId], map: "TenantManualCopy_company_manual_key")
  @@index([companyId], map: "TenantManualCopy_company_idx")
  @@index([sourceManualId], map: "TenantManualCopy_manual_idx")
  @@index([companyId, status], map: "TenantManualCopy_status_idx")
}

// =============================================================================
// System Tags for Tenant Classification
// =============================================================================

/// NEXUS System-level tags for classifying tenants (not tenant-scoped).
/// Used for selective document/manual distribution (e.g., "tier:premium", "region:west").
model SystemTag {
  id              String   @id @default(cuid())
  code            String   @unique // Unique identifier (e.g., "tier:premium", "feature:advanced-reporting")
  label           String // Display name (e.g., "Premium Tier")
  description     String? // Optional description
  category        String? // Grouping category (e.g., "tier", "region", "feature")
  color           String? // Hex color for UI display (e.g., "#f59e0b")
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy        User               @relation("SystemTagCreatedBy", fields: [createdByUserId], references: [id])
  companyTags      CompanySystemTag[]
  manualTargetTags ManualTargetTag[] // Manuals that target this tag

  @@index([category], map: "SystemTag_category_idx")
  @@index([active], map: "SystemTag_active_idx")
}

/// Join table assigning system tags to tenant companies.
/// Enables tag-based document/manual distribution.
model CompanySystemTag {
  id               String   @id @default(cuid())
  companyId        String
  systemTagId      String
  assignedByUserId String
  assignedAt       DateTime @default(now())

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  systemTag  SystemTag @relation(fields: [systemTagId], references: [id], onDelete: Cascade)
  assignedBy User      @relation("CompanySystemTagAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([companyId, systemTagId], map: "CompanySystemTag_company_tag_key")
  @@index([companyId], map: "CompanySystemTag_company_idx")
  @@index([systemTagId], map: "CompanySystemTag_tag_idx")
}

// =============================================================================
// Manuals / Document Collections
// =============================================================================

enum ManualStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ManualVersionChangeType {
  INITIAL
  DOCUMENT_ADDED
  DOCUMENT_REMOVED
  DOCUMENT_REORDERED
  CHAPTER_ADDED
  CHAPTER_REMOVED
  CHAPTER_REORDERED
  METADATA_UPDATED
}

/// A collection of documents organized into chapters (e.g., Safety Manual, Employee Handbook)
model Manual {
  id                  String       @id @default(cuid())
  code                String       @unique // Unique slug (e.g., "safety-manual")
  title               String
  description         String?      @db.Text
  status              ManualStatus @default(DRAFT)
  currentVersion      Int          @default(1) // Increments on structural changes
  publicSlug          String?      @unique // For branded URLs like /docs/safety-manual
  isPublic            Boolean      @default(false) // Whether accessible without auth
  publishToAllTenants Boolean      @default(false) // If true, ignores tag filters
  coverImageUrl       String?
  iconEmoji           String? // Optional emoji for display (e.g., "📘")
  createdByUserId     String
  publishedAt         DateTime? // When first published
  archivedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Ownership & Access Control
  ownerCompanyId      String? // Null = NEXUS System manual; Set = Tenant-owned manual
  isNexusInternal     Boolean      @default(false) // If true, only visible to users with requiredGlobalRoles
  requiredGlobalRoles GlobalRole[] // Which global roles can see this (when isNexusInternal=true)

  createdBy    User                @relation("ManualCreatedBy", fields: [createdByUserId], references: [id])
  ownerCompany Company?            @relation("ManualOwner", fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  chapters     ManualChapter[]
  documents    ManualDocument[]
  versions     ManualVersion[]
  views        ManualView[] // Saved view layouts
  targetTags   ManualTargetTag[] // Which tenant tags can see this manual
  tenantCopies TenantManualCopy[] // Distributed copies to tenants
  shareLinks   DocumentShareLink[] // Private share links

  @@index([status], map: "Manual_status_idx")
  @@index([isPublic], map: "Manual_public_idx")
  @@index([ownerCompanyId], map: "Manual_owner_idx")
  @@index([isNexusInternal], map: "Manual_nexus_internal_idx")
}

/// Version history for manual structure changes (not document content changes)
model ManualVersion {
  id                String                  @id @default(cuid())
  manualId          String
  version           Int // Sequential version number
  changeType        ManualVersionChangeType
  changeNotes       String? // Description of what changed
  structureSnapshot Json? // JSON snapshot of chapters/documents at this version
  createdByUserId   String
  createdAt         DateTime                @default(now())

  manual    Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ManualVersionCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([manualId, version], map: "ManualVersion_manual_version_key")
  @@index([manualId], map: "ManualVersion_manual_idx")
}

/// Sections/chapters within a manual
model ManualChapter {
  id          String   @id @default(cuid())
  manualId    String
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  active      Boolean  @default(true) // Soft delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manual    Manual           @relation(fields: [manualId], references: [id], onDelete: Cascade)
  documents ManualDocument[]

  @@index([manualId, sortOrder], map: "ManualChapter_manual_order_idx")
}

/// Join table linking system documents to manual chapters
model ManualDocument {
  id                     String   @id @default(cuid())
  manualId               String
  chapterId              String? // Null for root-level documents
  systemDocumentId       String
  sortOrder              Int      @default(0) // Order within chapter
  displayTitleOverride   String? // Optional override (e.g., "PPE Policy" instead of full title)
  includeInToc           Boolean  @default(true) // Whether to show in Table of Contents
  includeInPrint         Boolean  @default(true) // Whether to include content in print/PDF (false = "This Section Intentionally Blank")
  addedInManualVersion   Int // Which manual version added this doc
  removedInManualVersion Int? // Null if still active, set when removed
  active                 Boolean  @default(true) // Derived from removedInManualVersion being null
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  manual         Manual         @relation(fields: [manualId], references: [id], onDelete: Cascade)
  chapter        ManualChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  systemDocument SystemDocument @relation(fields: [systemDocumentId], references: [id], onDelete: Cascade)

  @@unique([manualId, systemDocumentId, removedInManualVersion], map: "ManualDocument_manual_doc_version_key")
  @@index([manualId, chapterId, sortOrder], map: "ManualDocument_chapter_order_idx")
  @@index([systemDocumentId], map: "ManualDocument_doc_idx")
}

/// Saved view layout for a manual — allows rearranging/merging/hiding sections
/// without modifying the canonical chapter/document structure.
model ManualView {
  id              String   @id @default(cuid())
  manualId        String
  name            String // e.g., "Executive Summary", "Compact"
  description     String?  @db.Text
  isDefault       Boolean  @default(false) // At most one default per manual
  mapping         Json // View mapping rules (compactSingleDocChapters, documentMoves, chapterOrder, etc.)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  manual    Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ManualViewCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([manualId, name], map: "ManualView_manual_name_key")
  @@index([manualId], map: "ManualView_manual_idx")
}

/// Join table for which tenant tags can access a manual
model ManualTargetTag {
  id          String   @id @default(cuid())
  manualId    String
  systemTagId String
  createdAt   DateTime @default(now())

  manual    Manual    @relation(fields: [manualId], references: [id], onDelete: Cascade)
  systemTag SystemTag @relation(fields: [systemTagId], references: [id], onDelete: Cascade)

  @@unique([manualId, systemTagId], map: "ManualTargetTag_manual_tag_key")
  @@index([manualId], map: "ManualTargetTag_manual_idx")
  @@index([systemTagId], map: "ManualTargetTag_tag_idx")
}

// =============================================================================
// OSHA / CFR Sync State
// =============================================================================

/// Tracks the synchronization state for imported CFR parts (e.g., 29 CFR 1926)
model OshaSyncState {
  id              String    @id @default(cuid())
  cfrTitle        Int // e.g., 29
  cfrPart         Int // e.g., 1926
  lastSyncedAt    DateTime?
  lastAmendedDate String? // ISO date from eCFR (e.g., "2024-07-01")
  lastContentHash String? // Hash of entire part XML for quick diff
  manualId        String? // The Manual record this sync populates
  sectionCount    Int       @default(0)
  syncStatus      String    @default("NEVER") // NEVER | SYNCING | SUCCESS | ERROR
  lastError       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([cfrTitle, cfrPart], map: "OshaSyncState_title_part_key")
}

// =============================================================================
// GovInfo Integration — Federal Register Alerts
// =============================================================================

/// Federal Register document tracked by the GovInfo FR monitor.
/// Created when the FR monitor finds rules/notices affecting watched CFR titles.
model FederalRegisterAlert {
  id              String    @id @default(cuid())
  granuleId       String    @unique // GovInfo granule ID (e.g., "2024-12345")
  packageId       String // Parent FR package (e.g., "FR-2024-08-03")
  documentType    String // RULE, PRORULE, NOTICE, PRESDOC
  title           String    @db.Text
  summary         String?   @db.Text
  cfrReferences   String[] // e.g., ["29 CFR 1926", "29 CFR 1910"]
  agencies        String[] // e.g., ["OSHA", "EPA"]
  publishedDate   DateTime
  effectiveDate   DateTime?
  commentDeadline DateTime?
  govInfoUrl      String // Link to GovInfo page
  frDocNumber     String? // Federal Register document number
  isRead          Boolean   @default(false)
  isRelevant      Boolean   @default(true) // Admin can mark irrelevant
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([publishedDate], map: "FRAlert_published_idx")
  @@index([documentType], map: "FRAlert_type_idx")
  @@index([isRead, isRelevant], map: "FRAlert_status_idx")
}

// =============================================================================
// GovInfo Integration — CFR Annual Snapshots & Diffs (Phase 4)
// =============================================================================

/// Snapshot metadata for an annual CFR edition (downloaded from GovInfo bulk data).
model CfrAnnualSnapshot {
  id           String   @id @default(cuid())
  cfrTitle     Int
  cfrPart      Int
  year         Int
  sectionCount Int      @default(0)
  contentHash  String // Hash of entire part XML for that year
  fetchedAt    DateTime @default(now())

  @@unique([cfrTitle, cfrPart, year], map: "CfrAnnualSnapshot_title_part_year_key")
}

/// Section-level diff between two annual CFR editions.
model CfrAnnualDiff {
  id         String   @id @default(cuid())
  cfrTitle   Int
  cfrPart    Int
  fromYear   Int
  toYear     Int
  sectionCfr String // e.g., "1926.501"
  changeType String // ADDED, REMOVED, MODIFIED
  summary    String?  @db.Text // Human-readable summary of changes
  createdAt  DateTime @default(now())

  @@index([cfrTitle, cfrPart, toYear], map: "CfrAnnualDiff_title_part_year_idx")
  @@index([sectionCfr], map: "CfrAnnualDiff_section_idx")
}

// =============================================================================
// GovInfo Integration — Regulatory Query Audit Log (Phase 3)
// =============================================================================

/// Audit log for regulatory AI queries made via the MCP integration.
model RegQueryLog {
  id            String   @id @default(cuid())
  userId        String
  question      String   @db.Text
  answer        String?  @db.Text
  sources       Json? // Array of { cfrRef, url }
  contextJson   Json? // The context passed with the query
  durationMs    Int? // How long the query took
  provider      String   @default("govinfo-mcp") // Which backend answered
  wasSuccessful Boolean  @default(true)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt], map: "RegQueryLog_user_created_idx")
}

// =============================================================================
// Publication Groups (for multi-tenant publishing)
// =============================================================================

/// Reusable group of tenants for bulk document publishing
model PublicationGroup {
  id              String   @id @default(cuid())
  code            String   @unique // e.g., "west-coast-clients"
  name            String // e.g., "West Coast Clients"
  description     String?  @db.Text
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User                     @relation("PublicationGroupCreatedBy", fields: [createdByUserId], references: [id])
  members   PublicationGroupMember[]

  @@index([code], map: "PublicationGroup_code_idx")
}

/// Join table linking companies to publication groups
model PublicationGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  companyId String
  addedAt   DateTime @default(now())

  group   PublicationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  company Company          @relation("PublicationGroupMembership", fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([groupId, companyId], map: "PublicationGroupMember_group_company_key")
  @@index([groupId], map: "PublicationGroupMember_group_idx")
  @@index([companyId], map: "PublicationGroupMember_company_idx")
}

// =============================================================================
// Document Share Links (Public & Private Sharing)
// =============================================================================

enum ShareLinkType {
  PUBLIC_URL // Accessible via public slug (no token needed)
  PRIVATE_LINK // Requires access token
}

/// Share link for private document/manual sharing with optional expiration
model DocumentShareLink {
  id               String        @id @default(cuid())
  systemDocumentId String? // Either document or manual, not both
  manualId         String? // Either document or manual, not both
  shareType        ShareLinkType @default(PRIVATE_LINK)
  accessToken      String        @unique // Random token for private links
  expiresAt        DateTime? // Optional expiration
  passcode         String? // Optional passcode (hashed)
  recipientEmail   String? // When set, access requires matching this email (secure share)
  recipientName    String? // Optional display name for the recipient
  accessCount      Int           @default(0) // Track number of views
  lastAccessedAt   DateTime? // When last accessed
  isActive         Boolean       @default(true) // Can be revoked
  createdByUserId  String
  createdAt        DateTime      @default(now())

  systemDocument SystemDocument? @relation(fields: [systemDocumentId], references: [id], onDelete: Cascade)
  manual         Manual?         @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("ShareLinkCreatedBy", fields: [createdByUserId], references: [id])

  @@index([accessToken], map: "DocShareLink_token_idx")
  @@index([systemDocumentId], map: "DocShareLink_doc_idx")
  @@index([manualId], map: "DocShareLink_manual_idx")
  @@index([recipientEmail], map: "DocShareLink_recipient_email_idx")
}

// =============================================================================
// Reader Groups (Secure Document Sharing)
// =============================================================================

/// Named group of email recipients for bulk secure document sharing
model ReaderGroup {
  id              String   @id @default(cuid())
  name            String // e.g., "West Coast Owners", "Board Members"
  description     String?  @db.Text
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User                @relation("ReaderGroupCreatedBy", fields: [createdByUserId], references: [id])
  members   ReaderGroupMember[]

  @@index([name], map: "ReaderGroup_name_idx")
}

/// Individual email member within a reader group
model ReaderGroupMember {
  id          String   @id @default(cuid())
  groupId     String
  email       String // Recipient email address
  displayName String? // Optional friendly name
  addedAt     DateTime @default(now())

  group ReaderGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, email], map: "ReaderGroupMember_group_email_key")
  @@index([groupId], map: "ReaderGroupMember_group_idx")
}

// =============================================================================
// Description Keeper (Saved Phrases)
// =============================================================================

/// Category for saved phrases, indicating where the phrase is typically used.
enum SavedPhraseCategory {
  INVOICE
  BILL
  DAILY_LOG
  GENERAL
}

/// Reusable text phrases that users can save and reuse across the application.
/// If userId is null, the phrase is company-wide (shared with all users in the company).
/// If userId is set, the phrase is personal to that user.
model SavedPhrase {
  id        String              @id @default(cuid())
  companyId String
  userId    String? // Null = company-wide, Set = user-specific
  category  SavedPhraseCategory @default(GENERAL)
  phrase    String              @db.Text
  label     String? // Optional short label for quick identification
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, category], map: "SavedPhrase_company_user_cat_idx")
  @@index([companyId, category], map: "SavedPhrase_company_cat_idx")
}

// =============================================================================
// Invoice Unit Codes (Company-managed dropdown list)
// =============================================================================

/// Company-managed list of unit codes for invoice line items.
/// Admins can add/edit/delete these codes (max 5 characters).
/// Examples: EA (each), HR (hour), SF (sq ft), LF (linear ft), etc.
model CompanyUnitCode {
  id        String   @id @default(cuid())
  companyId String
  code      String // Max 5 characters, e.g. "EA", "HR", "SF"
  label     String? // Optional friendly label, e.g. "Each", "Hour"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code], map: "CompanyUnitCode_company_code_key")
  @@index([companyId, sortOrder], map: "CompanyUnitCode_company_sort_idx")
}

// =============================================================================
// Supplier Bid Portal
// =============================================================================

/// Category for supplier tags (region, trade, or custom scope)
enum SupplierTagCategory {
  REGION // Geographic: FL, GA, TX, Southeast
  TRADE // Trade type: Roofer, Electrician, Plumber, Drywall
  SCOPE // Custom scope: Interior, Exterior, Commercial, Residential
}

/// Tags for categorizing suppliers (used for filtering when creating bid requests)
model SupplierTag {
  id        String              @id @default(cuid())
  companyId String
  category  SupplierTagCategory
  code      String // Short code, e.g. "FL", "ROOF"
  label     String // Display label, e.g. "Florida", "Roofing"
  color     String? // Optional hex color for UI
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments SupplierTagAssignment[]

  @@unique([companyId, category, code], map: "SupplierTag_company_cat_code_key")
  @@index([companyId, category], map: "SupplierTag_company_cat_idx")
}

/// Supplier/vendor/subcontractor in the company's directory
model Supplier {
  id        String  @id @default(cuid())
  companyId String
  name      String // Company/business name
  email     String? // Primary email
  phone     String? // Primary phone
  website   String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String? @default("US")

  // Default contact for bid requests
  defaultContactName  String?
  defaultContactEmail String?
  defaultContactPhone String?

  notes    String? @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts       SupplierContact[]
  tagAssignments SupplierTagAssignment[]
  bidRecipients  BidRequestRecipient[]
  bidResponses   BidResponse[]

  @@index([companyId, isActive], map: "Supplier_company_active_idx")
  @@index([companyId, name], map: "Supplier_company_name_idx")
}

/// Individual contact at a supplier (for multi-contact suppliers)
model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  email      String?
  phone      String?
  role       String? // e.g. "Sales Rep", "Estimator", "Owner"
  isPrimary  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier      Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bidRecipients BidRequestRecipient[]

  @@index([supplierId, isPrimary], map: "SupplierContact_supplier_primary_idx")
}

/// Join table: Supplier <-> SupplierTag
model SupplierTagAssignment {
  id         String   @id @default(cuid())
  supplierId String
  tagId      String
  createdAt  DateTime @default(now())

  supplier Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tag      SupplierTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([supplierId, tagId], map: "SupplierTagAssignment_supplier_tag_key")
  @@index([supplierId], map: "SupplierTagAssignment_supplier_idx")
  @@index([tagId], map: "SupplierTagAssignment_tag_idx")
}

/// Status of a bid request
enum BidRequestStatus {
  DRAFT // Being configured, not sent yet
  SENT // Sent to suppliers, awaiting responses
  CLOSED // Bidding closed (manually or by due date)
  CANCELED // Canceled by requestor
}

/// Status of a bid request recipient
enum BidRecipientStatus {
  PENDING // Not yet sent (draft)
  SENT // Email sent, awaiting response
  VIEWED // Supplier accessed the portal
  RESPONDED // Supplier submitted a response
  DECLINED // Supplier declined to bid
}

/// Cost type filter for bid request items
enum BidCostType {
  MATERIAL // Materials only
  LABOR // Labor only
  EQUIPMENT // Equipment only
  ALL // All cost types
}

/// Source type for bid request items
enum BidItemSourceType {
  PETL // From SowItem (PETL line)
  COMPONENT // From ComponentSummary
  MANUAL // Manually added
}

/// A bid request sent to one or more suppliers for pricing
model BidRequest {
  id        String @id @default(cuid())
  companyId String
  projectId String

  title       String // e.g. "Drywall Materials - 1548 Skyline"
  description String? @db.Text
  notes       String? @db.Text // Internal notes (not shared with suppliers)

  requestedByUserId String
  dueDate           DateTime? // When responses are due

  status BidRequestStatus @default(DRAFT)

  // Filter configuration (stored for reference/reuse)
  filterConfig Json? // { divisions: [], categories: [], costTypes: [] }

  sentAt     DateTime? // When first sent
  closedAt   DateTime? // When closed
  canceledAt DateTime? // When canceled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User                  @relation("BidRequestRequestedBy", fields: [requestedByUserId], references: [id])
  items       BidRequestItem[]
  recipients  BidRequestRecipient[]
  responses   BidResponse[]

  @@index([companyId, projectId], map: "BidRequest_company_project_idx")
  @@index([projectId, status], map: "BidRequest_project_status_idx")
  @@index([companyId, status, dueDate], map: "BidRequest_company_status_due_idx")
}

/// A line item in a bid request (shared with suppliers)
model BidRequestItem {
  id           String @id @default(cuid())
  bidRequestId String

  sourceType BidItemSourceType @default(PETL)
  sourceId   String? // sowItemId or componentSummaryId

  // Denormalized for display and CSV export
  catSel       String? // e.g. "DRY/1/2+"
  divisionCode String? // e.g. "09"
  description  String
  quantity     Float
  unit         String? // e.g. "SF", "EA", "LF"

  costType BidCostType @default(ALL)

  // Optional reference price (for comparison, not shown to suppliers)
  referenceUnitPrice Float?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  bidRequest    BidRequest        @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  responseItems BidResponseItem[]

  @@index([bidRequestId, sortOrder], map: "BidRequestItem_request_sort_idx")
}

/// A supplier recipient of a bid request (each gets unique token/PIN)
model BidRequestRecipient {
  id           String @id @default(cuid())
  bidRequestId String
  supplierId   String

  // Optional: override default supplier contact
  supplierContactId String?

  // Secure access credentials
  accessToken String    @unique // 32-char random hex for portal URL
  accessPin   String // 6-digit PIN, hashed with bcrypt
  pinAttempts Int       @default(0) // Track failed PIN attempts
  pinLockedAt DateTime? // Locked after too many attempts

  // Expiration
  expiresAt DateTime? // Optional token expiration

  status BidRecipientStatus @default(PENDING)

  // Tracking
  sentAt      DateTime? // When email was sent
  viewedAt    DateTime? // First portal access
  respondedAt DateTime? // When response submitted
  declinedAt  DateTime? // When declined

  // Email tracking (optional, for delivery status)
  emailMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest      BidRequest       @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  supplier        Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierContact SupplierContact? @relation(fields: [supplierContactId], references: [id], onDelete: SetNull)
  responses       BidResponse[]

  @@unique([bidRequestId, supplierId], map: "BidRecipient_request_supplier_key")
  @@index([accessToken], map: "BidRecipient_token_idx")
  @@index([bidRequestId, status], map: "BidRecipient_request_status_idx")
  @@index([supplierId], map: "BidRecipient_supplier_idx")
}

/// Status of a bid response
enum BidResponseStatus {
  DRAFT // Started but not submitted
  SUBMITTED // Submitted by supplier
}

/// Availability status for a bid response item
enum BidItemAvailability {
  IN_STOCK // Available immediately
  BACKORDERED // Available after lead time
  SPECIAL_ORDER // Requires special order
  UNAVAILABLE // Not available
}

/// A supplier's response to a bid request
model BidResponse {
  id           String @id @default(cuid())
  bidRequestId String
  recipientId  String
  supplierId   String

  status BidResponseStatus @default(DRAFT)

  // Computed totals
  totalAmount Float?

  // Supplier notes
  notes String? @db.Text

  // Submitter info (for non-NCC users)
  submittedByName  String?
  submittedByEmail String?
  submittedAt      DateTime?

  // If response was uploaded via CSV
  csvUploadPath String?
  csvUploadedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest BidRequest          @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  recipient  BidRequestRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items      BidResponseItem[]

  @@unique([recipientId], map: "BidResponse_recipient_key") // One response per recipient
  @@index([bidRequestId, status], map: "BidResponse_request_status_idx")
  @@index([supplierId], map: "BidResponse_supplier_idx")
}

/// A line item in a supplier's bid response
model BidResponseItem {
  id               String @id @default(cuid())
  bidResponseId    String
  bidRequestItemId String

  // Supplier's pricing
  unitPrice  Float?
  totalPrice Float? // unitPrice × quantity (computed)

  // Additional info
  notes        String? @db.Text
  leadTimeDays Int? // Days until available

  availability BidItemAvailability?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidResponse    BidResponse    @relation(fields: [bidResponseId], references: [id], onDelete: Cascade)
  bidRequestItem BidRequestItem @relation(fields: [bidRequestItemId], references: [id], onDelete: Cascade)

  @@unique([bidResponseId, bidRequestItemId], map: "BidResponseItem_response_item_key")
  @@index([bidResponseId], map: "BidResponseItem_response_idx")
}

// =============================================================================
// Cross-Tenant Person Search & Invite System
// =============================================================================

/// Status of a cross-tenant invite
enum CrossTenantInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

/// Cross-tenant invite with full token relationship tracking.
/// Enables tenants to invite people from the NEXUS System pool or other tenants
/// while maintaining audit trail of inviter/invitee relationships.
model CrossTenantInvite {
  id              String  @id @default(cuid())
  targetCompanyId String // Tenant inviting the person
  inviterUserId   String // User who initiated the invite
  inviteeUserId   String? // Existing user being invited (null if new person)
  inviteeEmail    String // Email for the invite
  inviteePhone    String? // Phone used to find the person

  token String @unique // Unique invite token for acceptance URL

  // Token relationship tracking for audit/analytics
  tenantToken        String? // Company.workerInviteToken snapshot at invite time
  inviterPeopleToken String // User.peopleToken of inviter
  inviteePeopleToken String? // User.peopleToken of invitee (if existing user)

  role   Role                    @default(MEMBER)
  status CrossTenantInviteStatus @default(PENDING)

  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  targetCompany Company @relation(fields: [targetCompanyId], references: [id])
  inviter       User    @relation("CrossTenantInviteInviter", fields: [inviterUserId], references: [id])
  invitee       User?   @relation("CrossTenantInviteInvitee", fields: [inviteeUserId], references: [id])

  // Link back to account link event if this invite triggered an account merge
  accountLinkEvent AccountLinkEvent?

  @@index([targetCompanyId, status], map: "CrossTenantInvite_company_status_idx")
  @@index([inviterUserId], map: "CrossTenantInvite_inviter_idx")
  @@index([inviteeUserId], map: "CrossTenantInvite_invitee_idx")
  @@index([inviteeEmail], map: "CrossTenantInvite_email_idx")
  @@index([inviteePhone], map: "CrossTenantInvite_phone_idx")
}

/// Alternate login email for a user (supports multi-email login).
/// When a phone number matches an existing user during invite acceptance,
/// the new email is added as an alias rather than creating a duplicate account.
model UserEmailAlias {
  id          String   @id @default(cuid())
  userId      String // Canonical User account this email belongs to
  email       String   @unique // Alternate email (can be used to login)
  verified    Boolean  @default(false) // Has the user verified ownership via SMS
  linkedAt    DateTime @default(now())
  linkEventId String? // AccountLinkEvent that created this alias

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "UserEmailAlias_user_idx")
}

/// Status of an account link event
enum AccountLinkStatus {
  PENDING_VERIFICATION // Linked but awaiting SMS verification
  VERIFIED // User confirmed via SMS
  DISPUTED // User claims this is not their account
  UNLINKED_BY_ADMIN // Admin manually unlinked
}

/// Tracks when email aliases are linked to canonical accounts.
/// Used for duplicate detection, audit trail, and admin review.
model AccountLinkEvent {
  id            String @id @default(cuid())
  primaryUserId String // Canonical account that absorbed the email
  linkedEmail   String // Email being linked as alias
  phone         String // Phone number that matched (identity anchor)

  // SMS verification
  verificationCode   String? // 6-digit code sent via SMS
  verificationSentAt DateTime? // When code was sent
  verifiedAt         DateTime? // When user verified (null = pending)

  // Trigger context
  triggeredByInviteId String?            @unique // CrossTenantInvite that caused this
  triggeredByInvite   CrossTenantInvite? @relation(fields: [triggeredByInviteId], references: [id])

  status AccountLinkStatus @default(PENDING_VERIFICATION)

  // Admin review
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryUser User @relation(fields: [primaryUserId], references: [id])

  @@index([primaryUserId], map: "AccountLinkEvent_primary_user_idx")
  @@index([linkedEmail], map: "AccountLinkEvent_email_idx")
  @@index([phone], map: "AccountLinkEvent_phone_idx")
  @@index([status, createdAt], map: "AccountLinkEvent_status_created_idx")
}

// =============================================================================
// Project Org Templates
// =============================================================================

/// Reusable project organization template ("Template Store").
/// Defines a structural skeleton of phases/areas/tasks that can be applied
/// to any project. Tenant-scoped (companyId set) or system-wide stock
/// templates (companyId null, isStock true).
model OrgTemplate {
  id              String   @id @default(cuid())
  companyId       String? // null = system-wide stock template
  name            String // "Residential New Construction", "Commercial TI"
  description     String?
  vertical        String? // "residential", "commercial", "restoration"
  isStock         Boolean  @default(false) // true = available to all tenants
  isActive        Boolean  @default(true)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company  Company?          @relation(fields: [companyId], references: [id])
  nodes    OrgTemplateNode[]
  projects Project[]

  @@index([companyId, isActive], map: "OrgTemplate_company_active_idx")
}

/// A single node in an org template tree. Top-level nodes (parentNodeId null)
/// sit directly under "Project Site". Nested nodes use parentNodeId for hierarchy.
model OrgTemplateNode {
  id                  String   @id @default(cuid())
  templateId          String
  parentNodeId        String? // null = top-level (under Project Site)
  sortOrder           Int      @default(0)
  code                String? // Group code: "Phase - 01", "Phase - 02"
  name                String // Group description: "Soil Test", "Framing"
  defaultPctComplete  Float    @default(0)
  defaultDurationDays Float? // optional schedule seed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  template OrgTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent   OrgTemplateNode?  @relation("OrgTemplateNodeParent", fields: [parentNodeId], references: [id])
  children OrgTemplateNode[] @relation("OrgTemplateNodeParent")

  @@index([templateId, parentNodeId, sortOrder], map: "OrgTemplateNode_template_parent_sort_idx")
}

// =============================================================================
// Drawings → BOM → PETL Pipeline
// =============================================================================

enum DrawingUploadStatus {
  UPLOADING
  EXTRACTING_TEXT
  EXTRACTING_BOM
  MATCHING
  READY // BOM extracted, matches scored, awaiting user review
  GENERATING // PETL generation in progress
  COMPLETED
  FAILED
}

/// An architectural drawing PDF uploaded for automated BOM extraction.
/// One upload = one PDF file (e.g. one volume of a construction drawing set).
model ProjectDrawingUpload {
  id        String @id @default(cuid())
  projectId String
  companyId String

  fileName      String
  storedPath    String // GCS path or local path
  pageCount     Int     @default(0)
  fileSizeBytes BigInt?

  status       DrawingUploadStatus @default(UPLOADING)
  errorMessage String?

  /// Extracted text per page: [{page: 1, sheetId: "S1.1", text: "..."}]
  extractedTextJson Json?

  /// AI extraction metadata (model used, token count, etc.)
  aiModelUsed    String?
  aiTokensUsed   Int?
  aiExtractionMs Int? // Time taken for AI extraction in ms

  /// Summary stats
  totalBomLines     Int @default(0)
  matchedBomLines   Int @default(0)
  unmatchedBomLines Int @default(0)

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project    Project          @relation(fields: [projectId], references: [id])
  company    Company          @relation(fields: [companyId], references: [id])
  bomLines   DrawingBomLine[]
  planSheets PlanSheet[]

  /// Link to the EstimateVersion created when PETL is generated
  generatedEstimateVersionId String?

  @@index([projectId, createdAt], map: "ProjectDrawingUpload_project_created_idx")
  @@index([companyId], map: "ProjectDrawingUpload_company_idx")
}

// =============================================================================
// Plan Sheet Viewer (multi-resolution page images)
// =============================================================================

enum PlanSheetStatus {
  PENDING // Placeholder created, waiting for worker to process
  PROCESSING // Worker is actively generating images
  READY // All tiers generated and uploaded to GCS
  FAILED // Processing failed
}

/// A single page extracted from a construction drawing PDF, stored as
/// multi-resolution WebP images (thumb / standard / master) in GCS.
model PlanSheet {
  id       String  @id @default(cuid())
  uploadId String
  pageNo   Int // 1-indexed PDF page
  sheetId  String? // Detected sheet ID: "A2", "S1", "E1"
  title    String? // "Floor Plan", "Foundation Plan"
  section  String? // "Architectural", "Structural"

  status PlanSheetStatus @default(PENDING)

  thumbPath     String? // GCS path: plan-sheets/{uploadId}/thumb/{pageNo}.webp
  standardPath  String? // GCS path: plan-sheets/{uploadId}/standard/{pageNo}.webp
  masterPath    String? // GCS path: plan-sheets/{uploadId}/master/{pageNo}.webp
  thumbBytes    Int     @default(0)
  standardBytes Int     @default(0)
  masterBytes   Int     @default(0)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload ProjectDrawingUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId, sortOrder], map: "PlanSheet_upload_sort_idx")
}

/// A single line item extracted from architectural drawings by AI.
/// Represents one material/product/system identified in the BOM.
model DrawingBomLine {
  id       String @id @default(cuid())
  uploadId String
  lineNo   Int

  /// CSI division (e.g. "03", "07", "22", "26")
  csiDivision     String?
  csiDivisionName String? // "Concrete", "Thermal & Moisture Protection", etc.

  /// What was extracted
  description   String // e.g. "Standing seam metal roof panels"
  specification String? // Manufacturer, model: "074113.A04" or "Kohler K-25077"
  qty           Float?
  unit          String? // EA, SF, LF, etc.

  /// Source reference in the drawing
  sourcePage  Int? // PDF page number
  sourceSheet String? // Sheet ID: "A-201", "P-601", "E-501"

  /// Cost book match
  matchedCostBookItemId String? // CompanyPriceListItem.id
  matchConfidence       Float? // 0–1 score
  matchMethod           String? // "exact_cat_sel", "fuzzy_description", "manual"

  /// Pricing (from matched cost book item or manual entry)
  unitPrice  Float?
  totalPrice Float?

  /// AI source tracking
  aiSource       String? // "xai", "anthropic", "openai", "consensus"
  consensusCount Int     @default(1) // How many providers found this item (2+ = consensus)

  /// Status flags
  isMatched     Boolean @default(false)
  isManualPrice Boolean @default(false) // User overrode the price
  needsReview   Boolean @default(true)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload       ProjectDrawingUpload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  costBookItem CompanyPriceListItem? @relation("DrawingBomCostBookMatch", fields: [matchedCostBookItemId], references: [id])

  @@index([uploadId, lineNo], map: "DrawingBomLine_upload_line_idx")
  @@index([uploadId, csiDivision], map: "DrawingBomLine_upload_division_idx")
  @@index([matchedCostBookItemId], map: "DrawingBomLine_cost_book_match_idx")
}

// =============================================================================
// Contextual Help System
// =============================================================================

/// In-app contextual help items displayed via the "?" overlay.
/// Each item corresponds to a `data-help="{helpKey}"` attribute in the UI.
model HelpItem {
  id String @id @default(cuid())

  /// Unique key matching data-help attribute, e.g. "schedule-gantt-toggle"
  helpKey String @unique

  /// Display title shown in help popover
  title String

  /// Brief 1-2 sentence description
  brief String @db.Text

  /// Optional link to full SOP document (stores document ID)
  sopId String?

  /// Optional anchor/section within the SOP
  sopSection String?

  /// Optional video tutorial URL (YouTube, Loom, etc.)
  videoUrl String?

  /// Whether this help item is active/visible
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([helpKey], map: "HelpItem_helpKey_idx")
  @@index([isActive], map: "HelpItem_isActive_idx")
}

// ════════════════════════════════════════════════════════════════════
// Supplier Bidding System
// ════════════════════════════════════════════════════════════════════

enum BidPackageStatus {
  DRAFT // PM is building the package
  OPEN // Suppliers can submit bids
  CLOSED // Bidding closed, no more submissions
  AWARDED // Bid(s) awarded to supplier(s)
  CANCELED // Package canceled
}

enum InvitationStatus {
  PENDING // Invite sent, not opened
  OPENED // Supplier opened the link
  SUBMITTED // Bid submitted
  DECLINED // Supplier declined to bid
}

enum BidStatus {
  DRAFT // Supplier is working on it
  SUBMITTED // Final submission
  AMENDED // Supplier amended after initial submission
  WITHDRAWN // Supplier withdrew bid
  AWARDED // Bid was awarded (winner)
  DECLINED // PM declined this bid
}

model BidPackage {
  id              String  @id @default(cuid())
  companyId       String
  projectId       String
  estimateId      String? // Optional: link to specific estimate version
  createdByUserId String

  title       String // "Phase 1 Cabinets Bid"
  description String?          @db.Text // Instructions, scope notes
  status      BidPackageStatus @default(DRAFT)

  dueDate   DateTime? // Submission deadline
  openedAt  DateTime? // When bidding opened
  closedAt  DateTime? // When bidding closed
  awardedAt DateTime? // When bid was awarded

  // Attachments (plans, SOW, specs)
  attachmentUrls Json? // Array of GCS/S3 URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])
  createdBy User    @relation("BidPackageCreatedBy", fields: [createdByUserId], references: [id])

  lineItems   BidPackageLineItem[]
  invitations SupplierInvitation[]
  bids        SupplierBid[]

  @@index([companyId, projectId], map: "BidPackage_company_project_idx")
  @@index([status, dueDate], map: "BidPackage_status_due_idx")
}

model BidPackageLineItem {
  id           String @id @default(cuid())
  bidPackageId String
  lineNo       Int // Display order (1, 2, 3...)

  // Link to estimate line item (optional)
  estimateLineItemId String?

  // Line item details
  category    String? // "CAB", "DRY", "PLM" (Xactimate cat)
  description String  @db.Text // "White Shaker Base Cabinet 24x34.5x24"
  unit        String // "EA", "SF", "LF"
  qty         Float // 12.0

  // Optional: reference specs
  specHash String? // Link to CatalogItem if cabinet/material
  notes    String? @db.Text // Special instructions per line

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidPackage   BidPackage            @relation(fields: [bidPackageId], references: [id], onDelete: Cascade)
  bidLineItems SupplierBidLineItem[]

  @@index([bidPackageId, lineNo], map: "BidPackageLineItem_package_line_idx")
}

model SupplierInvitation {
  id           String @id @default(cuid())
  bidPackageId String

  // Supplier contact info (external, not Nexus users)
  supplierName String // "ABC Supply Co."
  contactName  String? // "John Smith"
  contactEmail String? // john@abcsupply.com
  contactPhone String? // +1-555-123-4567

  // Access token (embedded in link)
  accessToken String @unique // cuid or JWT

  status InvitationStatus @default(PENDING)

  invitedAt   DateTime  @default(now())
  openedAt    DateTime? // When supplier first clicked link
  submittedAt DateTime? // When bid submitted
  declinedAt  DateTime?

  bidPackage BidPackage    @relation(fields: [bidPackageId], references: [id], onDelete: Cascade)
  bids       SupplierBid[]

  @@index([bidPackageId], map: "SupplierInvitation_package_idx")
  @@index([accessToken], map: "SupplierInvitation_token_idx")
  @@index([contactEmail], map: "SupplierInvitation_email_idx")
}

model SupplierBid {
  id           String @id @default(cuid())
  bidPackageId String
  invitationId String

  status     BidStatus @default(DRAFT)
  revisionNo Int       @default(1) // Increments on amend

  // Supplier notes
  notes String? @db.Text // "Lead time 4-6 weeks"

  // Totals (computed from line items)
  subtotal Float?
  tax      Float?
  shipping Float?
  total    Float?

  submittedAt DateTime? // Initial submission
  amendedAt   DateTime? // Last amendment
  awardedAt   DateTime? // When PM awarded

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidPackage BidPackage            @relation(fields: [bidPackageId], references: [id], onDelete: Cascade)
  invitation SupplierInvitation    @relation(fields: [invitationId], references: [id])
  lineItems  SupplierBidLineItem[]

  @@index([bidPackageId, status], map: "SupplierBid_package_status_idx")
  @@index([invitationId], map: "SupplierBid_invitation_idx")
}

model SupplierBidLineItem {
  id                   String @id @default(cuid())
  bidId                String
  bidPackageLineItemId String // Links to BidPackageLineItem

  unitPrice  Float? // Supplier's unit price
  totalPrice Float? // unitPrice * qty

  // Supplier notes per line
  notes        String? @db.Text // "Substituting with equivalent model XYZ"
  leadTimeDays Int? // Delivery timeline

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid             SupplierBid        @relation(fields: [bidId], references: [id], onDelete: Cascade)
  packageLineItem BidPackageLineItem @relation(fields: [bidPackageLineItemId], references: [id])

  @@unique([bidId, bidPackageLineItemId], map: "SupplierBidLineItem_bid_line_key")
  @@index([bidId], map: "SupplierBidLineItem_bid_idx")
}

// ===================================================================
// Living Membership — Billing, Subscriptions & Module Licensing
// ===================================================================

/// The tenant's Stripe subscription (one per company). Contains multiple
/// subscription items — one for each active module.
model TenantSubscription {
  id                String             @id @default(cuid())
  companyId         String
  stripeSubId       String             @unique
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId], map: "TenantSubscription_company_idx")
}

/// Payment methods attached to a tenant's Stripe customer. Cards go through
/// Stripe Elements; bank accounts go through Plaid Link → Stripe processor token.
model TenantPaymentMethod {
  id                    String            @id @default(cuid())
  companyId             String
  stripePaymentMethodId String            @unique
  type                  PaymentMethodType
  last4                 String?
  brand                 String? // visa, mastercard, etc.
  plaidItemId           String? // set when linked via Plaid
  isDefault             Boolean           @default(false)
  createdAt             DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId], map: "TenantPaymentMethod_company_idx")
}

/// Tracks which NCC modules a tenant currently has active. Each record maps
/// to a Stripe subscription item on the tenant's subscription.
model TenantModuleSubscription {
  id                       String    @id @default(cuid())
  companyId                String
  moduleCode               String
  stripeSubscriptionItemId String?   @unique
  enabledAt                DateTime  @default(now())
  disabledAt               DateTime?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, moduleCode], name: "TenantModuleSub_company_module_key")
  @@index([companyId], map: "TenantModuleSub_company_idx")
}

/// Canonical catalog of all NCC modules available for purchase. Each module
/// maps to a Stripe Product + Price. Seeded by migration / admin script.
model ModuleCatalog {
  id                   String       @id @default(cuid())
  code                 String       @unique
  label                String
  description          String?
  stripeProductId      String? // Stripe Product ID
  stripePriceId        String? // Default monthly Price ID
  monthlyPrice         Int? // Display price in cents (e.g. 4900 = $49.00)
  pricingModel         PricingModel @default(MONTHLY)
  projectUnlockPrice   Int? // One-time unlock price in cents (PER_PROJECT only)
  oneTimePurchasePrice Int? // One-time lifetime access price (ONE_TIME_PURCHASE only)
  isCore               Boolean      @default(false) // CORE modules can't be toggled off
  sortOrder            Int          @default(0)
  active               Boolean      @default(true)
  prerequisites        String[]     @default([]) // Module codes that must be enabled first

  /// Optional link to a CAM (Competitive Advantage Module) SystemDocument.
  /// Populated by the CAM sync process; allows "Learn more" on billing page.
  camDocumentId String?         @unique
  camDocument   SystemDocument? @relation("ModuleCamDocument", fields: [camDocumentId], references: [id], onDelete: SetNull)
}

/// Stripe webhook events stored for idempotency and audit. Every processed
/// webhook is recorded here so duplicates are safely ignored.
model BillingEvent {
  id            String   @id @default(cuid())
  companyId     String?
  stripeEventId String   @unique
  eventType     String // e.g. invoice.paid, customer.subscription.updated
  payload       Json
  processedAt   DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])

  @@index([companyId], map: "BillingEvent_company_idx")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum PaymentMethodType {
  CARD
  US_BANK_ACCOUNT
}

/// Pricing model for a module in the catalog.
enum PricingModel {
  MONTHLY // Standard recurring subscription
  PER_PROJECT // One-time unlock fee per project
  PER_USE // Pay-per-use (future)
  ONE_TIME_PURCHASE // One-time purchase for lifetime access (Master Costbook, Golden PETL, Golden BOM)
}

/// Tracks one-time per-project feature unlocks. When a PM unlocks a
/// PER_PROJECT module on a specific project, a record is created here
/// and the feature becomes available indefinitely on that project.
model ProjectFeatureUnlock {
  id                    String   @id @default(cuid())
  companyId             String
  projectId             String
  featureCode           String // matches ModuleCatalog.code
  stripePaymentIntentId String? // Stripe PI for the one-time charge
  amountCents           Int // price charged at time of unlock
  unlockedByUserId      String? // user who triggered the unlock
  unlockedAt            DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([companyId, projectId, featureCode], name: "ProjectFeatureUnlock_company_project_feature_key")
  @@index([companyId], map: "ProjectFeatureUnlock_company_idx")
  @@index([projectId], map: "ProjectFeatureUnlock_project_idx")
}

// ===================================================================
// Banking — Plaid Transactions Integration
// ===================================================================

enum BankConnectionStatus {
  ACTIVE
  REQUIRES_REAUTH
  DISCONNECTED
}

/// A linked bank account via Plaid for pulling transactions.
/// One BankConnection per Plaid account selected during Link.
model BankConnection {
  id                String               @id @default(cuid())
  companyId         String
  plaidItemId       String
  plaidAccessToken  String // encrypted at rest via app-level encryption
  institutionId     String?
  institutionName   String?
  accountId         String // Plaid account_id selected during Link
  accountName       String?
  accountMask       String? // last 4 digits
  accountType       String? // depository, credit, etc.
  accountSubtype    String? // checking, savings, credit card, etc.
  syncCursor        String? // Plaid transactions/sync cursor; null = initial sync
  lastSyncedAt      DateTime?
  status            BankConnectionStatus @default(ACTIVE)
  connectedByUserId String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company      Company           @relation(fields: [companyId], references: [id])
  connectedBy  User              @relation("BankConnectionConnectedBy", fields: [connectedByUserId], references: [id])
  transactions BankTransaction[]

  @@unique([companyId, accountId], name: "BankConnection_company_account_key")
  @@index([companyId], map: "BankConnection_company_idx")
  @@index([plaidItemId], map: "BankConnection_plaid_item_idx")
}

/// Individual bank transaction pulled from Plaid transactions/sync.
model BankTransaction {
  id                   String    @id @default(cuid())
  companyId            String
  bankConnectionId     String
  plaidTransactionId   String    @unique
  accountId            String // Plaid account_id
  date                 DateTime  @db.Date
  datetime             DateTime? // Full timestamp when available
  name                 String // Transaction description from bank
  merchantName         String?
  amount               Float // Positive = money out (debit), negative = money in (credit)
  isoCurrencyCode      String?   @default("USD")
  primaryCategory      String? // Plaid personal_finance_category primary
  detailedCategory     String? // Plaid personal_finance_category detailed
  pending              Boolean   @default(false)
  pendingTransactionId String? // Links to the posted version
  paymentChannel       String? // online, in_store, other
  transactionType      String? // place, digital, special, unresolved

  // Reconciliation — optional project linkage
  projectId String?

  // Transaction disposition — working table lifecycle
  disposition TransactionDisposition @default(UNREVIEWED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company                 @relation(fields: [companyId], references: [id])
  bankConnection BankConnection          @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  project        Project?                @relation("BankTransactionProject", fields: [projectId], references: [id])
  ccPaymentLinks CreditCardPaymentLink[]

  @@index([companyId, date], map: "BankTransaction_company_date_idx")
  @@index([bankConnectionId], map: "BankTransaction_connection_idx")
  @@index([companyId, primaryCategory], map: "BankTransaction_company_category_idx")
  @@index([pending], map: "BankTransaction_pending_idx")
  @@index([companyId, projectId], map: "BankTransaction_company_project_idx")
  @@index([companyId, disposition], map: "BankTransaction_company_disposition_idx")
}

// ===================================================================
// CSV Transaction Imports — HD, Chase, Apple Card
// ===================================================================

enum CsvImportSource {
  HD_PRO_XTRA
  CHASE_BANK
  APPLE_CARD
}

/// A single CSV file upload / import batch.
model CsvImportBatch {
  id               String          @id @default(cuid())
  companyId        String
  source           CsvImportSource
  fileName         String
  rawCsv           String?         @db.Text // Original CSV content preserved for undo
  rowCount         Int             @default(0)
  totalAmount      Float           @default(0)
  dateRangeStart   DateTime?       @db.Date
  dateRangeEnd     DateTime?       @db.Date
  uploadedByUserId String
  createdAt        DateTime        @default(now())

  company      Company               @relation(fields: [companyId], references: [id])
  uploadedBy   User                  @relation("CsvImportBatchUploadedBy", fields: [uploadedByUserId], references: [id])
  transactions ImportedTransaction[]

  @@index([companyId], map: "CsvImportBatch_company_idx")
  @@index([companyId, source], map: "CsvImportBatch_company_source_idx")
}

/// Individual transaction row parsed from an imported CSV.
model ImportedTransaction {
  id        String          @id @default(cuid())
  companyId String
  batchId   String
  source    CsvImportSource

  // Core fields (all sources)
  date        DateTime @db.Date
  description String
  amount      Float // Positive = expense/purchase, negative = return/credit
  merchant    String?

  // HD Pro Xtra fields
  jobNameRaw     String?
  jobName        String? // Normalized via job-name-map
  sku            String?
  department     String?
  category       String?
  subcategory    String?
  purchaser      String?
  qty            Float?
  unitPrice      Float?
  storeNumber    String? // HD store ID (e.g. "6528")
  transactionRef String? // HD Transaction ID / Order Number / Invoice Number
  registerNumber String? // HD register number

  // Chase bank statement fields
  postingDate    DateTime? @db.Date
  txnType        String? // CHECK_PAID, ACH_CREDIT, DEBIT_CARD, etc.
  runningBalance Float?
  checkOrSlip    String?

  // Apple Card fields
  clearingDate DateTime? @db.Date
  cardCategory String?
  cardHolder   String?

  // Deduplication fingerprint — SHA-256 of key fields per source type
  fingerprint String?

  // Reconciliation — optional project linkage
  projectId String?

  // Prescreening — intelligent project suggestion
  prescreenProjectId       String?
  prescreenConfidence      Float? // 0.0–1.0
  prescreenReason          String? // Human-readable explanation of signals
  prescreenStatus          PrescreenStatus @default(PENDING)
  prescreenRejectionReason String? // User explanation when rejected

  // Store-to-card reconciliation — links HD line items to credit card charges
  reconciledWithId String? // ID of the matching ImportedTransaction
  reconciledAt     DateTime?

  // Purchase Reconciliation — CC-to-checking audit chain
  reconciliationStatus  ReconciliationStatus  @default(UNLINKED)
  expenseClassification ExpenseClassification @default(UNCLASSIFIED)

  // Transaction disposition — working table lifecycle
  disposition TransactionDisposition @default(UNREVIEWED)

  createdAt DateTime @default(now())

  company          Company                 @relation(fields: [companyId], references: [id])
  batch            CsvImportBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  project          Project?                @relation("ImportedTransactionProject", fields: [projectId], references: [id])
  prescreenProject Project?                @relation("ImportedTransactionPrescreenProject", fields: [prescreenProjectId], references: [id])
  ccPaymentLinks   CreditCardPaymentLink[]

  @@unique([companyId, source, fingerprint], name: "ImportedTransaction_company_source_fingerprint_key")
  @@index([companyId, date], map: "ImportedTransaction_company_date_idx")
  @@index([companyId, source], map: "ImportedTransaction_company_source_idx")
  @@index([batchId], map: "ImportedTransaction_batch_idx")
  @@index([companyId, jobName], map: "ImportedTransaction_company_jobName_idx")
  @@index([companyId, merchant], map: "ImportedTransaction_company_merchant_idx")
  @@index([companyId, prescreenStatus], map: "ImportedTransaction_company_prescreen_idx")
  @@index([companyId, storeNumber], map: "ImportedTransaction_company_store_idx")
  @@index([reconciledWithId], map: "ImportedTransaction_reconciledWith_idx")
  @@index([companyId, reconciliationStatus], map: "ImportedTransaction_company_reconStatus_idx")
  @@index([companyId, expenseClassification], map: "ImportedTransaction_company_expenseClass_idx")
  @@index([companyId, disposition], map: "ImportedTransaction_company_disposition_idx")
}

// ===================================================================
// Transaction Disposition Audit Log
// ===================================================================

/// Audit trail for every disposition change on a transaction.
/// Captures who, when, what changed, and a mandatory note.
model TransactionDispositionLog {
  id                  String                @id @default(cuid())
  companyId           String
  transactionId       String // ImportedTransaction.id or BankTransaction.id
  transactionSource   String // "PLAID" | "HD_PRO_XTRA" | "CHASE_BANK" | "APPLE_CARD"
  previousDisposition TransactionDisposition
  newDisposition      TransactionDisposition
  note                String // Mandatory — reason for the disposition change
  userId              String
  userName            String // Denormalized for display
  createdAt           DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation("TransactionDispositionLogUser", fields: [userId], references: [id])

  @@index([companyId, transactionId], map: "TxnDispositionLog_company_txn_idx")
  @@index([companyId, createdAt], map: "TxnDispositionLog_company_date_idx")
}

// ===================================================================
// Transaction Tags — freeform grouping for filtering
// ===================================================================

/// Company-scoped tag for grouping transactions into eclectic buckets.
model TransactionTag {
  id        String  @id @default(cuid())
  companyId String
  name      String
  color     String? // Hex color for UI badge
  createdAt DateTime @default(now())

  company     Company                    @relation(fields: [companyId], references: [id])
  assignments TransactionTagAssignment[]

  @@unique([companyId, name], name: "TransactionTag_company_name_key")
  @@index([companyId], map: "TransactionTag_company_idx")
}

/// Junction: links a tag to a specific transaction (imported or Plaid).
model TransactionTagAssignment {
  id                String   @id @default(cuid())
  transactionId     String // ImportedTransaction.id or BankTransaction.id
  transactionSource String // "PLAID" | "HD_PRO_XTRA" | "CHASE_BANK" | "APPLE_CARD"
  tagId             String
  assignedByUserId  String?
  assignedAt        DateTime @default(now())

  tag TransactionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId], name: "TransactionTagAssignment_txn_tag_key")
  @@index([tagId], map: "TransactionTagAssignment_tag_idx")
  @@index([transactionId], map: "TransactionTagAssignment_txn_idx")

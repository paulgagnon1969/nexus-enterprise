/// Raw user activity event. Lives in Postgres for a 14-day rolling window,
/// then archived to GCS encrypted vault and purged.
model UserActivityEvent {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  eventType String // LOGIN, MODULE_OPEN, RECORD_CREATE, RECORD_UPDATE, RECORD_DELETE, PAGE_VIEW
  module    String // projects, financial, daily_logs, messaging, timecards, etc.
  entityId  String? // ID of the affected record (optional)
  metadata  Json? // Additional context (page path, entity type, etc.)
  createdAt DateTime @default(now())

  @@index([companyId, createdAt], map: "UserActivityEvent_company_created_idx")
  @@index([userId, createdAt], map: "UserActivityEvent_user_created_idx")
  @@index([module, eventType, createdAt], map: "UserActivityEvent_module_event_created_idx")
}

/// Pre-computed daily rollup of user activity. Permanent storage — powers dashboard queries.
model ActivityDailyRollup {
  id         String   @id @default(cuid())
  companyId  String
  userId     String
  date       DateTime @db.Date // truncated to day
  module     String
  eventType  String
  eventCount Int      @default(0)
  metadata   Json? // aggregated metadata (e.g., avg content length)

  @@unique([companyId, userId, date, module, eventType], name: "ActivityDailyRollup_unique")
  @@index([companyId, date], map: "ActivityDailyRollup_company_date_idx")
  @@index([userId, date], map: "ActivityDailyRollup_user_date_idx")
}

/// Pre-computed weekly rollup of user activity. Permanent storage.
model ActivityWeeklyRollup {
  id         String   @id @default(cuid())
  companyId  String
  userId     String
  weekStart  DateTime @db.Date // Monday of the week
  module     String
  eventType  String
  eventCount Int      @default(0)

  @@unique([companyId, userId, weekStart, module, eventType], name: "ActivityWeeklyRollup_unique")
  @@index([companyId, weekStart], map: "ActivityWeeklyRollup_company_week_idx")
  @@index([userId, weekStart], map: "ActivityWeeklyRollup_user_week_idx")
}

/// TUCKS gaming detection flag. Created by the nightly scoring cron when a
/// user's daily-log behaviour scores ≥ 0.4 on the composite gaming metric.
/// PM+ roles review flags and can dismiss, confirm, or coach.
model GamingFlag {
  id              String    @id @default(cuid())
  companyId       String
  userId          String
  flagDate        DateTime  @db.Date // the day being flagged
  gamingScore     Float // composite 0.0–1.0
  volumeScore     Float     @default(0)
  burstScore      Float     @default(0)
  entropyScore    Float     @default(0)
  similarityScore Float     @default(0)
  ratioScore      Float     @default(0)
  dailyLogIds     Json? // string[] of DailyLog IDs that triggered the flag
  status          String    @default("PENDING") // PENDING | DISMISSED | CONFIRMED | COACHED
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime  @default(now())

  @@unique([companyId, userId, flagDate], name: "GamingFlag_company_user_date_key")
  @@index([companyId, status, flagDate], map: "GamingFlag_company_status_date_idx")
  @@index([userId, flagDate], map: "GamingFlag_user_date_idx")
}


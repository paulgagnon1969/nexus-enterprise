# =============================================================================
# Shadow Server Environment — NCC Home Deployment
# =============================================================================
# Copy this file to .env.shadow and fill in all values.
# Used by: docker compose -f infra/docker/docker-compose.shadow.yml up -d
# =============================================================================

# ---------- Postgres ----------
SHADOW_PG_USER=nexus_user
SHADOW_PG_PASSWORD=CHANGE_ME
SHADOW_PG_DB=nexus_db

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=nexus-uploads
MINIO_PUBLIC_URL=https://api-staging.ncc.nfsgrp.com/files

# ---------- Storage provider (minio for shadow, gcs for GCP) ----------
STORAGE_PROVIDER=minio

# ---------- API secrets (copy from production) ----------
JWT_SECRET=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ---------- GCS (only needed if STORAGE_PROVIDER=gcs) ----------
# GCS_UPLOADS_BUCKET=
# GCS_PUBLIC_BASE_URL=

# ---------- Web build args ----------
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------- Cloudflare Tunnel ----------
# Path to the credentials JSON from `cloudflared tunnel create nexus-shadow`
CLOUDFLARE_CREDENTIALS_FILE=~/.cloudflared/<TUNNEL_ID>.json

# ---------- LiveKit (video calls) ----------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# ---------- Email ----------
EMAIL_FROM=noreply@nfsgrp.com

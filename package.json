{
  "name": "nexus-enterprise",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "postinstall": "if [ -z \"$EAS_BUILD_RUNNER\" ]; then npm -w @repo/database run prisma:generate; fi",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:web": "turbo dev --filter=web",
    "dev:contact-sync": "npm --prefix apps/contact-sync run tauri:dev",
    "build:contact-sync": "npm --prefix apps/contact-sync run tauri:build",
    "dev:all": "turbo dev --parallel",
    "dev:worker": "npm -w api run worker:dev",
    "dev:nuke": "bash ./scripts/dev-nuke-restart.sh",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write .",
    "db:migrate:dev": "bash ./scripts/db-migrate-cloud.sh",
    "db:migrate:prod": "bash ./scripts/db-migrate-prod.sh",
    "deploy:prod:api": "bash ./deploy-api-prod.sh",
    "deploy:prod:api:env": "bash ./scripts/deploy-api-prod-env.sh",
    "sops:sync": "ts-node scripts/import-sops.ts --all",
    "sops:sync:dry": "ts-node scripts/import-sops.ts --all --dry-run",
    "cams:sync": "ts-node scripts/import-sops.ts --all --dir docs/cams",
    "docs:sync": "npm run sops:sync && npm run cams:sync",
    "api-token:generate": "ts-node scripts/generate-api-token.ts",
    "seed:checklist": "ts-node scripts/seed-checklist-costbook.ts",
    "compile:cam-manual": "ts-node scripts/compile-cam-manual.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.39.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "prettier": "^3.7.4",
    "puppeteer": "^24.37.5",
    "ts-node": "^10.9.2",
    "turbo": "^2.7.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-fastify": "^11.1.9",
    "expo": "~55.0.2",
    "expo-av": "^16.0.8",
    "messagebird": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "punycode": "^2.3.1",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "@react-native/virtualized-lists": "0.83.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}

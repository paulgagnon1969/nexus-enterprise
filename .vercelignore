docs/data/
docs/plan-sheets/

# API runtime uploads (286MB)
apps/api/uploads/

# Infrastructure / scripts not needed for web build
infra/
scripts/

# Git / CI
.git/
.github/

# Misc
.DS_Store
*.log
*.mov
*.rtf
*.app
promotion/

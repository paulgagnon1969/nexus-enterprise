    { "pattern": "^607\\s*clearwater", "normalized": "607 CLEARWATER LARGO", "note": "607 Clearwater Largo Rd" },
    { "pattern": "^100\\s*causeway", "normalized": "100 CAUSEWAY BLVD", "note": "100 Causeway Blvd" },

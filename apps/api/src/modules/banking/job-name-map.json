    { "pattern": "^(carrizo|carizzo|charizo)", "normalized": "CARRIZO SPRINGS", "note": "Carrizo Springs project" },
    { "pattern": "^110\\s*(1st|first|cedar|st\\s*st)", "normalized": "110 1ST ST", "note": "110 1st Street / Cedar" },

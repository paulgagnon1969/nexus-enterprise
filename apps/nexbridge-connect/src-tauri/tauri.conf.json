{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexBRIDGE Connect",
  "identifier": "com.nexus.nexbridge-connect",
  "version": "1.2.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexBRIDGE Connect",
        "width": 960,
        "height": 800,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "contacts_helper",
      "photogrammetry_helper"
    ],
    "resources": [
      "src/contacts_windows.ps1",
      "scripts/analyze_mesh.py",
      "scripts/sketchup_import.rb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://staging-api.nfsgrp.com/updates/check/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBRTJCOUM3OTUxQUZGNjEKUldSaC94cVZ4N25pcXU2K3A1TnNsY3N4Skd6N3BmQ0lnUEJqZFl3RGozRElmMTZpb2p6LzRuMy8K"
    }
  }
}

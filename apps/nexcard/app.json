{
  "expo": {
    "name": "NexCard",
    "slug": "nexcard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pg1969.nexcard",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFinancialDataDescription": "NexCard reads your financial transactions to display spending trends, sync to accounting software, and help you manage your finances across all cards and accounts."
      }
    },
    "android": {
      "package": "com.pg1969.nexcard",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "react-native-plaid-link-sdk"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
